+package de.szalkowski.activitylauncher.core.util
+
+import android.content.ComponentName
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertThrows
+import org.junit.Test
+
+class PackageStateCommandBuilderTest {
+    @Test
+    fun `builds per-user application enable command`() {
+        assertEquals(
+            listOf("/system/bin/pm", "enable", "--user", "10", "com.example.app"),
+            PackageStateCommandBuilder.buildApplicationCommand("com.example.app", true, 10),
+        )
+    }
+
+    @Test
+    fun `builds per-user activity disable command`() {
+        assertEquals(
+            listOf(
+                "/system/bin/pm",
+                "disable-user",
+                "--user",
+                "0",
+                "com.example.app/com.example.app.HiddenActivity",
+            ),
+            PackageStateCommandBuilder.buildActivityCommand(
+                ComponentName("com.example.app", "com.example.app.HiddenActivity"),
+                false,
+                0,
+            ),
+        )
+    }
+
+    @Test
+    fun `rejects shell syntax in targets`() {
+        assertThrows(IllegalArgumentException::class.java) {
+            PackageStateCommandBuilder.buildApplicationCommand("com.example;id", false, 0)
+        }
+    }
+}
