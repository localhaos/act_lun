+        if (activity.isEnabled != false) return
+
+        when {
+            shizukuExecutor.state() == ShizukuState.GRANTED -> executeEnable(activity, useShizuku = true)
+            rootPackageStateExecutor.isAvailable() -> executeEnable(activity, useShizuku = false)
