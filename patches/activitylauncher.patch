@@ -0,0 +1,145 @@
+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.ComponentName
+import android.content.Context
+import android.content.Intent
+import android.content.pm.ActivityInfo
+import android.content.pm.PackageManager
+import dagger.hilt.android.qualifiers.ApplicationContext
+import de.szalkowski.activitylauncher.data.database.LaunchMethodDao
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchExecutor
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchResult
+import de.szalkowski.activitylauncher.domain.model.ActivityLaunchBackend
+import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.withContext
+import javax.inject.Inject
+
+data class ActivityLaunchMethodAttempt(
+    val backend: ActivityLaunchBackend,
+    val success: Boolean,
+    val message: String?,
+)
+
+/** Tests the first safe available backend and stores the result for this exact component. */
+class ActivityLaunchMethodTester @Inject constructor(
+    @ApplicationContext private val context: Context,
+    private val launchMethodDao: LaunchMethodDao,
+    private val shizukuExecutor: ShizukuActivityLaunchExecutor,
+    private val rootPluginExecutor: RootPluginActivityLaunchExecutor,
+    private val jvmExecutor: JvmActivityLaunchExecutor,
+    private val nativeExecutor: NativeActivityLaunchExecutor,
+    private val rootExecutor: RootActivityLaunchExecutor,
+) {
+    suspend fun test(intent: Intent): List<ActivityLaunchMethodAttempt> = withContext(Dispatchers.IO) {
+        val component = requireNotNull(intent.component) { "An explicit component is required" }
+        val packageName = component.packageName
+        val className = component.className
+        val activityInfo = getActivityInfo(component)
+        if (activityInfo != null && !isComponentEnabled(component, activityInfo)) {
+            return@withContext listOf(
+                ActivityLaunchMethodAttempt(
+                    ActivityLaunchBackend.DEFAULT,
+                    false,
+                    "Aktywność jest wyłączona. Włącz ją przełącznikiem i spróbuj ponownie.",
+                ),
+            )
+        }
+
+        val history = launchMethodDao.getHistory(packageName, className).associateBy { it.backend }
+        val restricted = activityInfo?.let { !it.exported || !it.permission.isNullOrBlank() } == true
+        val defaultOrder = if (restricted) {
+            buildList {
+                if (shizukuExecutor.remoteUid() == ROOT_UID) {
+                    add(ActivityLaunchBackend.SHIZUKU_PLUS)
+                }
+                add(ActivityLaunchBackend.ROOT_SU)
+                add(ActivityLaunchBackend.ROOT_PLUGIN)
+                if (!contains(ActivityLaunchBackend.SHIZUKU_PLUS)) {
+                    add(ActivityLaunchBackend.SHIZUKU_PLUS)
+                }
+                add(ActivityLaunchBackend.DEFAULT)
+                add(ActivityLaunchBackend.JVM)
+                add(ActivityLaunchBackend.JNI_NATIVE)
+            }
+        } else {
+            listOf(
+                ActivityLaunchBackend.DEFAULT,
+                ActivityLaunchBackend.SHIZUKU_PLUS,
+                ActivityLaunchBackend.ROOT_PLUGIN,
+                ActivityLaunchBackend.JVM,
+                ActivityLaunchBackend.JNI_NATIVE,
+                ActivityLaunchBackend.ROOT_SU,
+            )
+        }
+        val executors = mapOf<ActivityLaunchBackend, ActivityLaunchExecutor>(
+            ActivityLaunchBackend.SHIZUKU_PLUS to shizukuExecutor,
+            ActivityLaunchBackend.ROOT_PLUGIN to rootPluginExecutor,
+            ActivityLaunchBackend.JVM to jvmExecutor,
+            ActivityLaunchBackend.JNI_NATIVE to nativeExecutor,
+            ActivityLaunchBackend.ROOT_SU to rootExecutor,
+        )
+        val available = defaultOrder.filter { backend ->
+            when (backend) {
+                ActivityLaunchBackend.DEFAULT -> true
+                ActivityLaunchBackend.SHIZUKU_PLUS -> shizukuExecutor.state() == ShizukuState.GRANTED
+                else -> executors[backend]?.isAvailable() == true
+            }
+        }
+        val candidates = if (restricted) {
+            available
+        } else {
+            available.filterNot { it == ActivityLaunchBackend.ROOT_SU }.sortedWith(
+                compareByDescending<ActivityLaunchBackend> { history[it.name]?.successes ?: 0 }
+                    .thenByDescending { history[it.name]?.lastSuccessAt ?: 0L }
+                    .thenBy { defaultOrder.indexOf(it) },
+            ) + available.filter { it == ActivityLaunchBackend.ROOT_SU }
+        }
+
+        val attempts = mutableListOf<ActivityLaunchMethodAttempt>()
+        for (backend in candidates) {
+            val result = when (backend) {
+                ActivityLaunchBackend.DEFAULT -> launchDefault(intent)
+                else -> requireNotNull(executors[backend]).launch(intent)
+            }
+            val attempt = ActivityLaunchMethodAttempt(backend, result.started, result.message)
+            attempts += attempt
+            launchMethodDao.record(
+                packageName = packageName,
+                className = className,
+                backend = backend.name,
+                success = result.started,
+                message = result.message,
+            )
+            if (result.started) break
+        }
+        attempts
+    }
+
+    private fun launchDefault(intent: Intent): ActivityLaunchResult = runCatching {
+        context.startActivity(Intent(intent).addFlags(Intent.FLAG_ACTIVITY_NEW_TASK))
+        ActivityLaunchResult(true)
+    }.getOrElse { error ->
+        ActivityLaunchResult(false, error.message ?: error::class.java.simpleName)
+    }
+
+    @Suppress("DEPRECATION")
+    private fun getActivityInfo(component: ComponentName): ActivityInfo? = runCatching {
+        context.packageManager.getActivityInfo(component, PackageManager.GET_DISABLED_COMPONENTS)
+    }.getOrNull()
+
+    private fun isComponentEnabled(
+        component: ComponentName,
+        info: ActivityInfo,
+    ): Boolean = when (context.packageManager.getComponentEnabledSetting(component)) {
+        PackageManager.COMPONENT_ENABLED_STATE_ENABLED -> info.applicationInfo.enabled
+        PackageManager.COMPONENT_ENABLED_STATE_DISABLED,
+        PackageManager.COMPONENT_ENABLED_STATE_DISABLED_USER,
+        PackageManager.COMPONENT_ENABLED_STATE_DISABLED_UNTIL_USED,
+        -> false
+        else -> info.enabled && info.applicationInfo.enabled
+    }
+
+    private companion object {
+        const val ROOT_UID = 0
+    }
+}
