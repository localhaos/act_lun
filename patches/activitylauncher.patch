@@ -0,0 +1,157 @@
+package de.szalkowski.activitylauncher.data.launcher;
+
+import android.content.Context;
+import android.os.Bundle;
+
+import androidx.annotation.Keep;
+
+import java.io.IOException;
+import java.io.InputStream;
+import java.io.InputStreamReader;
+import java.nio.charset.StandardCharsets;
+import java.util.Arrays;
+
+/** Isolated Shizuku UserService which executes only the app's allowlisted framework commands. */
+public final class ShizukuCommandUserService extends IShizukuCommandService.Stub {
+    public static final String RESULT_EXIT_CODE = "exit_code";
+    public static final String RESULT_STDOUT = "stdout";
+    public static final String RESULT_STDERR = "stderr";
+
+    private static final int INVALID_COMMAND = 126;
+    private static final int PROCESS_FAILED = 127;
+    private static final int PROCESS_TIMEOUT = 124;
+    private static final int MAX_ARGUMENT_COUNT = 128;
+    private static final int MAX_ARGUMENT_CHARS = 16_384;
+    private static final int MAX_TOTAL_ARGUMENT_CHARS = 65_536;
+    private static final int MAX_OUTPUT_CHARS = 16_384;
+    private static final long PROCESS_TIMEOUT_MILLIS = 20_000L;
+
+    @Keep
+    public ShizukuCommandUserService() {}
+
+    @Keep
+    public ShizukuCommandUserService(Context context) {}
+
+    @Override
+    public void destroy() {
+        System.exit(0);
+    }
+
+    @Override
+    public synchronized Bundle execute(String[] command) {
+        String validationError = validate(command);
+        if (validationError != null) {
+            return result(INVALID_COMMAND, "", validationError);
+        }
+
+        Process process = null;
+        try {
+            process = new ProcessBuilder(Arrays.asList(command)).redirectErrorStream(false).start();
+            process.getOutputStream().close();
+
+            BoundedStreamReader stdout = new BoundedStreamReader(process.getInputStream());
+            BoundedStreamReader stderr = new BoundedStreamReader(process.getErrorStream());
+            Thread stdoutThread = new Thread(stdout, "activitylauncher-shizuku-worker-stdout");
+            Thread stderrThread = new Thread(stderr, "activitylauncher-shizuku-worker-stderr");
+            stdoutThread.setDaemon(true);
+            stderrThread.setDaemon(true);
+            stdoutThread.start();
+            stderrThread.start();
+
+            int exitCode = waitFor(process);
+            stdoutThread.join(2_000L);
+            stderrThread.join(2_000L);
+            return result(exitCode, stdout.value(), stderr.value());
+        } catch (InterruptedException error) {
+            Thread.currentThread().interrupt();
+            return result(PROCESS_FAILED, "", "Shizuku worker interrupted");
+        } catch (Throwable error) {
+            String message = error.getMessage();
+            return result(
+                    PROCESS_FAILED,
+                    "",
+                    message == null ? error.getClass().getSimpleName() : message);
+        } finally {
+            if (process != null) {
+                process.destroy();
+            }
+        }
+    }
+
+    private static int waitFor(Process process) throws InterruptedException {
+        long deadline = System.currentTimeMillis() + PROCESS_TIMEOUT_MILLIS;
+        while (System.currentTimeMillis() < deadline) {
+            try {
+                return process.exitValue();
+            } catch (IllegalThreadStateException ignored) {
+                Thread.sleep(25L);
+            }
+        }
+        process.destroy();
+        return PROCESS_TIMEOUT;
+    }
+
+    private static String validate(String[] command) {
+        if (command == null || command.length < 2 || command.length > MAX_ARGUMENT_COUNT) {
+            return "Invalid Shizuku command length";
+        }
+        int totalChars = 0;
+        for (String argument : command) {
+            if (argument == null || argument.length() > MAX_ARGUMENT_CHARS) {
+                return "Invalid Shizuku command argument";
+            }
+            totalChars += argument.length();
+            if (totalChars > MAX_TOTAL_ARGUMENT_CHARS) {
+                return "Shizuku command is too large";
+            }
+        }
+
+        if ("/system/bin/am".equals(command[0])) {
+            return "start".equals(command[1]) ? null : "Unsupported activity-manager operation";
+        }
+        if ("/system/bin/pm".equals(command[0])) {
+            return "enable".equals(command[1]) || "disable-user".equals(command[1])
+                    ? null
+                    : "Unsupported package-manager operation";
+        }
+        return "Shizuku executable is not allowlisted";
+    }
+
+    private static Bundle result(int exitCode, String stdout, String stderr) {
+        Bundle bundle = new Bundle();
+        bundle.putInt(RESULT_EXIT_CODE, exitCode);
+        bundle.putString(RESULT_STDOUT, stdout);
+        bundle.putString(RESULT_STDERR, stderr);
+        return bundle;
+    }
+
+    private static final class BoundedStreamReader implements Runnable {
+        private final InputStream input;
+        private final StringBuilder output = new StringBuilder();
+
+        BoundedStreamReader(InputStream input) {
+            this.input = input;
+        }
+
+        @Override
+        public void run() {
+            try (InputStreamReader reader =
+                    new InputStreamReader(input, StandardCharsets.UTF_8)) {
+                char[] buffer = new char[1_024];
+                int count;
+                while ((count = reader.read(buffer)) >= 0) {
+                    int remaining = MAX_OUTPUT_CHARS - output.length();
+                    if (remaining > 0) {
+                        output.append(buffer, 0, Math.min(count, remaining));
+                    }
+                }
+            } catch (IOException ignored) {
+                // Process teardown can close a stream while it is being drained.
+            }
+        }
+
+        String value() {
+            return output.toString();
+        }
+    }
+}
