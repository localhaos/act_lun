+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.Intent
+import de.szalkowski.activitylauncher.core.util.ActivityCommandBuilder
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchExecutor
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchResult
+import de.szalkowski.activitylauncher.domain.model.ActivityLaunchBackend
+import javax.inject.Inject
+
+/**
+ * Uses the bundled JNI worker for a fixed, argument-vector-only `am` spawn.
+ * It does not elevate privileges; Shizuku is deliberately kept separate.
+ */
+class NativeActivityLaunchExecutor @Inject constructor() : ActivityLaunchExecutor {
+    override val backend: ActivityLaunchBackend = ActivityLaunchBackend.JNI_NATIVE
+
+    override fun isAvailable(): Boolean = NativeWorker.isAvailable()
+
+    override fun launch(intent: Intent): ActivityLaunchResult {
+        if (!NativeWorker.isAvailable()) {
+            return ActivityLaunchResult(false, "Native worker is unavailable for this ABI")
+        }
+        return runCatching {
+            val pid = NativeWorker.spawn(ActivityCommandBuilder.buildStartCommand(intent))
+            if (pid != null) {
+                val exitCode = NativeWorker.waitFor(pid)
+                if (exitCode == 0) {
+                    ActivityLaunchResult(started = true)
+                } else {
+                    ActivityLaunchResult(false, "am zakończyło pracę z kodem $exitCode")
+                }
+            } else {
+                ActivityLaunchResult(false, "Native worker could not spawn activity manager")
+            }
+        }.getOrElse { error ->
+            ActivityLaunchResult(
+                started = false,
+                message = error.message ?: error::class.java.simpleName,
+            )
+        }
+    }
+}
