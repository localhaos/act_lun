+        viewModelScope.launch {
+            val commandResult = withContext(Dispatchers.IO) {
+                val primary = if (useShizuku) {
+                    shizukuPackageStateExecutor.setActivityEnabled(activity.componentName, true)
+                } else {
+                    rootPackageStateExecutor.setActivityEnabled(activity.componentName, true)
+                }
+                if (useShizuku && !primary.success && rootPackageStateExecutor.isAvailable()) {
+                    rootPackageStateExecutor.setActivityEnabled(activity.componentName, true)
+                } else {
+                    primary
+                }
+            }
