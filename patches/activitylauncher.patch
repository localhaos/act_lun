+package de.szalkowski.activitylauncher.core.util
+
+import android.content.ComponentName
+import android.content.Intent
+import android.os.Bundle
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertFalse
+import org.junit.Assert.assertTrue
+import org.junit.Test
+import org.mockito.kotlin.doReturn
+import org.mockito.kotlin.mock
+import org.mockito.kotlin.whenever
+
+class ActivityCommandBuilderTest {
+    @Test
+    fun `builds an argument vector and preserves values with shell syntax`() {
+        val component = mock<ComponentName> {
+            on { flattenToString() } doReturn "com.example.app/com.example.app.HiddenActivity"
+        }
+        val extras = mock<Bundle>()
+        whenever(extras.keySet()).thenReturn(setOf("enabled", "payload"))
+        whenever(extras.get("payload")).thenReturn("$(touch /data/local/tmp/should-not-run)")
+        whenever(extras.get("enabled")).thenReturn(true)
+        val intent = mock<Intent>()
+        whenever(intent.component).thenReturn(component)
+        whenever(intent.action).thenReturn("com.example.ACTION")
+        whenever(intent.data).thenReturn(null)
+        whenever(intent.type).thenReturn(null)
+        whenever(intent.categories).thenReturn(null)
+        whenever(intent.extras).thenReturn(extras)
+        whenever(intent.flags).thenReturn(Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK)
+
+        val command = ActivityCommandBuilder.buildStartCommand(intent)
+
+        assertEquals("/system/bin/am", command.first())
+        assertTrue(command.contains("$(touch /data/local/tmp/should-not-run)"))
+        assertTrue(command.contains("--es"))
+        assertTrue(command.contains("--ez"))
+        assertTrue(command.contains("--user"))
+        assertTrue(command.contains("current"))
+        assertTrue(command.contains("-W"))
+        assertTrue(command.contains("-f"))
+        assertTrue(command.contains("0x10008000"))
+        assertFalse(command.contains("sh"))
+        assertFalse(command.contains("-c"))
+    }
+}
