+                _errorMessage.emit(R.string.error_shizuku_not_running)
+            }
+            ShizukuState.UNSUPPORTED -> viewModelScope.launch {
+                _errorMessage.emit(R.string.error_shizuku_unsupported)
+            }
+        }
+    }
