@@ -0,0 +1,93 @@
+package de.szalkowski.activitylauncher.entrypoint
+
+import android.content.ClipData
+import android.content.ClipboardManager
+import android.content.Context
+import android.os.Bundle
+import android.view.MenuItem
+import android.widget.Toast
+import androidx.appcompat.app.AppCompatActivity
+import androidx.core.view.isVisible
+import androidx.lifecycle.lifecycleScope
+import dagger.hilt.android.AndroidEntryPoint
+import de.szalkowski.activitylauncher.R
+import de.szalkowski.activitylauncher.data.audit.PackageAuditScanner
+import de.szalkowski.activitylauncher.databinding.ActivityAuditBinding
+import de.szalkowski.activitylauncher.presentation.audit.PackageAuditFormatter
+import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.launch
+import kotlinx.coroutines.withContext
+import javax.inject.Inject
+
+@AndroidEntryPoint
+class AuditActivity : AppCompatActivity() {
+    @Inject
+    lateinit var packageAuditScanner: PackageAuditScanner
+
+    private lateinit var binding: ActivityAuditBinding
+    private val packageName: String by lazy {
+        intent.getStringExtra(EXTRA_PACKAGE_NAME).orEmpty()
+    }
+
+    override fun onCreate(savedInstanceState: Bundle?) {
+        super.onCreate(savedInstanceState)
+
+        binding = ActivityAuditBinding.inflate(layoutInflater)
+        setContentView(binding.root)
+        setSupportActionBar(binding.toolbar)
+        supportActionBar?.setDisplayHomeAsUpEnabled(true)
+
+        binding.btRunAudit.setOnClickListener { runAudit() }
+        binding.btCopyReport.setOnClickListener { copyReport() }
+
+        if (packageName.isBlank()) {
+            binding.tvAuditStatus.setText(R.string.error_invalid_activity_link)
+            binding.btRunAudit.isEnabled = false
+        } else {
+            runAudit()
+        }
+    }
+
+    override fun onOptionsItemSelected(item: MenuItem): Boolean {
+        return if (item.itemId == android.R.id.home) {
+            finish()
+            true
+        } else {
+            super.onOptionsItemSelected(item)
+        }
+    }
+
+    private fun runAudit() {
+        binding.btRunAudit.isEnabled = false
+        binding.pbAudit.isVisible = true
+        binding.tvAuditStatus.text = getString(R.string.audit_running, packageName)
+
+        lifecycleScope.launch {
+            val result = runCatching {
+                withContext(Dispatchers.IO) { packageAuditScanner.scan(packageName) }
+            }
+            result.onSuccess { audit ->
+                binding.tvAuditStatus.text = getString(R.string.audit_complete, audit.packageName)
+                binding.tvAuditReport.text = PackageAuditFormatter.format(audit)
+            }.onFailure { error ->
+                binding.tvAuditStatus.text = getString(
+                    R.string.audit_failed,
+                    error.message ?: error::class.java.simpleName,
+                )
+                binding.tvAuditReport.text = ""
+            }
+            binding.pbAudit.isVisible = false
+            binding.btRunAudit.isEnabled = true
+        }
+    }
+
+    private fun copyReport() {
+        val clipboard = getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
+        clipboard.setPrimaryClip(ClipData.newPlainText("Activity Launcher audit", binding.tvAuditReport.text))
+        Toast.makeText(this, R.string.audit_copied, Toast.LENGTH_SHORT).show()
+    }
+
+    companion object {
+        const val EXTRA_PACKAGE_NAME = "packageName"
+    }
+}
diff --git a/app/src/main/java/de/szalkowski/activitylauncher/presentation/audit/PackageAuditFormatter.kt b/app/src/main/java/de/szalkowski/activitylauncher/presentation/audit/PackageAuditFormatter.kt
