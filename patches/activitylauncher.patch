+package de.szalkowski.activitylauncher.core.util
+
+import android.content.ComponentName
+
+/**
+ * Builds the small, fixed command set used to change package/component state.
+ * No shell is involved and callers cannot inject additional flags or commands.
+ */
+object PackageStateCommandBuilder {
+    private const val PACKAGE_MANAGER = "/system/bin/pm"
+    private val packageNamePattern = Regex("[A-Za-z][A-Za-z0-9_]*(?:\\.[A-Za-z0-9_]+)*")
+    private val classNamePattern = Regex("[A-Za-z_$][A-Za-z0-9_$.]*")
+
+    fun buildApplicationCommand(
+        packageName: String,
+        enabled: Boolean,
+        userId: Int,
+    ): List<String> {
+        validatePackageName(packageName)
+        validateUserId(userId)
+        return buildCommand(enabled, userId, packageName)
+    }
+
+    fun buildActivityCommand(
+        componentName: ComponentName,
+        enabled: Boolean,
+        userId: Int,
+    ): List<String> {
+        validatePackageName(componentName.packageName)
+        require(classNamePattern.matches(componentName.className)) {
+            "Invalid activity class name"
+        }
+        validateUserId(userId)
+        return buildCommand(enabled, userId, componentName.flattenToString())
+    }
+
+    private fun buildCommand(enabled: Boolean, userId: Int, target: String): List<String> = listOf(
+        PACKAGE_MANAGER,
+        if (enabled) "enable" else "disable-user",
+        "--user",
+        userId.toString(),
+        target,
+    )
+
+    private fun validatePackageName(packageName: String) {
+        require(packageNamePattern.matches(packageName)) { "Invalid package name" }
+    }
+
+    private fun validateUserId(userId: Int) {
+        require(userId >= 0) { "Invalid user id" }
+    }
+}
