@@ -0,0 +1,154 @@
+package de.szalkowski.activitylauncher.entrypoint
+
+import android.content.ClipData
+import android.content.ClipboardManager
+import android.content.Context
+import android.os.Bundle
+import android.view.MenuItem
+import android.widget.Toast
+import androidx.appcompat.app.AlertDialog
+import androidx.appcompat.app.AppCompatActivity
+import androidx.core.view.isVisible
+import androidx.lifecycle.lifecycleScope
+import dagger.hilt.android.AndroidEntryPoint
+import de.szalkowski.activitylauncher.R
+import de.szalkowski.activitylauncher.data.audit.PackageAuditScanner
+import de.szalkowski.activitylauncher.data.launcher.PackageStateChangeResult
+import de.szalkowski.activitylauncher.data.launcher.ShizukuActivityLaunchExecutor
+import de.szalkowski.activitylauncher.data.launcher.ShizukuPackageStateExecutor
+import de.szalkowski.activitylauncher.data.launcher.ShizukuState
+import de.szalkowski.activitylauncher.databinding.ActivityAuditBinding
+import de.szalkowski.activitylauncher.presentation.audit.PackageAuditFormatter
+import kotlinx.coroutines.Dispatchers
+import kotlinx.coroutines.launch
+import kotlinx.coroutines.withContext
+import javax.inject.Inject
+
+@AndroidEntryPoint
+class AuditActivity : AppCompatActivity() {
+    @Inject
+    lateinit var packageAuditScanner: PackageAuditScanner
+
+    @Inject
+    lateinit var shizukuExecutor: ShizukuActivityLaunchExecutor
+
+    @Inject
+    lateinit var packageStateExecutor: ShizukuPackageStateExecutor
+
+    private lateinit var binding: ActivityAuditBinding
+    private val targetPackageName: String by lazy {
+        intent.getStringExtra(EXTRA_PACKAGE_NAME).orEmpty()
+    }
+
+    override fun onCreate(savedInstanceState: Bundle?) {
+        super.onCreate(savedInstanceState)
+
+        binding = ActivityAuditBinding.inflate(layoutInflater)
+        setContentView(binding.root)
+        setSupportActionBar(binding.toolbar)
+        supportActionBar?.setDisplayHomeAsUpEnabled(true)
+
+        binding.btRunAudit.setOnClickListener { runAudit() }
+        binding.btCopyReport.setOnClickListener { copyReport() }
+        binding.btEnableApp.setOnClickListener { confirmApplicationStateChange(true) }
+        binding.btDisableApp.setOnClickListener { confirmApplicationStateChange(false) }
+
+        if (targetPackageName.isBlank()) {
+            binding.tvAuditStatus.setText(R.string.error_invalid_activity_link)
+            binding.btRunAudit.isEnabled = false
+        } else {
+            runAudit()
+        }
+    }
+
+    override fun onOptionsItemSelected(item: MenuItem): Boolean {
+        return if (item.itemId == android.R.id.home) {
+            finish()
+            true
+        } else {
+            super.onOptionsItemSelected(item)
+        }
+    }
+
+    private fun runAudit() {
+        binding.btRunAudit.isEnabled = false
+        binding.pbAudit.isVisible = true
+        binding.tvAuditStatus.text = getString(R.string.audit_running, targetPackageName)
+
+        lifecycleScope.launch {
+            val result = runCatching {
+                withContext(Dispatchers.IO) { packageAuditScanner.scan(targetPackageName) }
+            }
+            result.onSuccess { audit ->
+                binding.tvAuditStatus.text = getString(R.string.audit_complete, audit.packageName)
+                binding.tvAuditReport.text = PackageAuditFormatter.format(audit)
+            }.onFailure { error ->
+                binding.tvAuditStatus.text = getString(
+                    R.string.audit_failed,
+                    error.message ?: error::class.java.simpleName,
+                )
+                binding.tvAuditReport.text = ""
+            }
+            binding.pbAudit.isVisible = false
+            binding.btRunAudit.isEnabled = true
+        }
+    }
+
+    private fun copyReport() {
+        val clipboard = getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
+        clipboard.setPrimaryClip(ClipData.newPlainText("Activity Launcher audit", binding.tvAuditReport.text))
+        Toast.makeText(this, R.string.audit_copied, Toast.LENGTH_SHORT).show()
+    }
+
+    private fun confirmApplicationStateChange(enabled: Boolean) {
+        val messageRes = if (enabled) R.string.confirm_enable_app else R.string.confirm_disable_app
+        val actionRes = if (enabled) R.string.action_enable_app else R.string.action_disable_app
+        AlertDialog.Builder(this)
+            .setTitle(getString(actionRes))
+            .setMessage(getString(messageRes, targetPackageName))
+            .setNegativeButton(android.R.string.cancel, null)
+            .setPositiveButton(actionRes) { _, _ -> changeApplicationState(enabled) }
+            .show()
+    }
+
+    private fun changeApplicationState(enabled: Boolean) {
+        when (shizukuExecutor.state()) {
+            ShizukuState.GRANTED -> executeApplicationStateChange(enabled)
+            ShizukuState.DENIED -> shizukuExecutor.requestPermission { granted ->
+                runOnUiThread {
+                    if (granted) {
+                        executeApplicationStateChange(enabled)
+                    } else {
+                        Toast.makeText(this, R.string.error_shizuku_permission, Toast.LENGTH_SHORT).show()
+                    }
+                }
+            }
+            ShizukuState.STOPPED -> Toast.makeText(this, R.string.error_shizuku_not_running, Toast.LENGTH_SHORT).show()
+            ShizukuState.UNSUPPORTED -> Toast.makeText(this, R.string.error_shizuku_unsupported, Toast.LENGTH_SHORT).show()
+        }
+    }
+
+    private fun executeApplicationStateChange(enabled: Boolean) {
+        binding.btEnableApp.isEnabled = false
+        binding.btDisableApp.isEnabled = false
+        lifecycleScope.launch {
+            val result = withContext(Dispatchers.IO) {
+                packageStateExecutor.setApplicationEnabled(targetPackageName, enabled)
+            }
+            showStateChangeResult(result)
+            binding.btEnableApp.isEnabled = true
+            binding.btDisableApp.isEnabled = true
+        }
+    }
+
+    private fun showStateChangeResult(result: PackageStateChangeResult) {
+        val message = result.message ?: getString(
+            if (result.success) R.string.state_change_success else R.string.state_change_failed_generic,
+        )
+        Toast.makeText(this, message, Toast.LENGTH_LONG).show()
+    }
+
+    companion object {
+        const val EXTRA_PACKAGE_NAME = "packageName"
+    }
+}
