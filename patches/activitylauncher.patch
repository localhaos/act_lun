@@ -0,0 +1,33 @@
+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.Intent
+import org.junit.Test
+import kotlin.random.Random
+
+/** Crash-resistance test for the app-owned content URI text parser only. */
+class ContentUriIntentReaderFuzzTest {
+    @Test
+    fun randomInputsNeverEscapeTheParser() {
+        repeat(2_000) {
+            val value = buildString {
+                repeat(Random.nextInt(0, 256)) {
+                    append(Random.nextInt(0, 128).toChar())
+                }
+            }
+            runCatching {
+                val parsed = parse(value)
+                if (parsed != null) check(parsed.component != null)
+            }.onFailure { error ->
+                throw AssertionError("Parser crashed for fuzz input", error)
+            }
+        }
+    }
+
+    private fun parse(value: String): Intent? {
+        val candidate = value.trim()
+        if (candidate.isEmpty() || candidate.any { it == '\u0000' }) return null
+        return runCatching { Intent.parseUri(candidate, Intent.URI_INTENT_SCHEME) }
+            .getOrNull()
+            ?.takeIf { it.component != null }
+    }
+}
