@@ -0,0 +1,66 @@
+package de.szalkowski.activitylauncher.core.util
+
+import android.content.Intent
+import android.net.Uri
+import android.os.Bundle
+
+/**
+ * Builds an argument vector for Android's activity manager without going through a shell.
+ * Keeping every value as a separate argument avoids command-injection bugs in executor backends.
+ */
+object ActivityCommandBuilder {
+    private const val ACTIVITY_MANAGER = "/system/bin/am"
+
+    fun buildStartCommand(intent: Intent): List<String> {
+        val component = requireNotNull(intent.component) { "An explicit component is required" }
+        val command = mutableListOf(ACTIVITY_MANAGER, "start")
+
+        intent.action?.takeIf { it.isNotBlank() }?.let {
+            command += listOf("-a", it)
+        }
+        intent.data?.let { data: Uri ->
+            command += listOf("-d", data.toString())
+        }
+        intent.type?.takeIf { it.isNotBlank() }?.let {
+            command += listOf("-t", it)
+        }
+        intent.categories
+            ?.asSequence()
+            ?.sorted()
+            ?.forEach { category -> command += listOf("-c", category) }
+
+        command += listOf("-n", component.flattenToString())
+        appendExtras(command, intent.extras)
+        return command
+    }
+
+    private fun appendExtras(command: MutableList<String>, extras: Bundle?) {
+        extras?.keySet()
+            ?.asSequence()
+            ?.sorted()
+            ?.forEach { key ->
+                val value = extras.get(key) ?: return@forEach
+                when (value) {
+                    is String -> command += listOf("--es", key, value)
+                    is Int -> command += listOf("--ei", key, value.toString())
+                    is Long -> command += listOf("--el", key, value.toString())
+                    is Boolean -> command += listOf("--ez", key, value.toString())
+                    is Float -> command += listOf("--ef", key, value.toString())
+                    is Double -> command += listOf("--ed", key, value.toString())
+                    is Uri -> command += listOf("--eu", key, value.toString())
+                    is Array<*> -> {
+                        val strings = value.filterIsInstance<String>()
+                        if (strings.size == value.size) {
+                            command += listOf("--esa", key, strings.joinToString(","))
+                        }
+                    }
+                    is ArrayList<*> -> {
+                        val strings = value.filterIsInstance<String>()
+                        if (strings.size == value.size) {
+                            command += listOf("--esa", key, strings.joinToString(","))
+                        }
+                    }
+                }
+            }
+    }
+}
