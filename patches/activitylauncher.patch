@@ -0,0 +1,26 @@
+package de.szalkowski.activitylauncher.data.launcher
+
+/** Small JNI worker that only spawns the fixed Android activity-manager binary. */
+object NativeWorker {
+    private val loaded: Boolean by lazy {
+        runCatching {
+            System.loadLibrary("activitylauncher_worker")
+            true
+        }.getOrDefault(false)
+    }
+
+    @JvmStatic
+    external fun nativeSpawn(command: Array<String>): Int
+
+    @JvmStatic
+    external fun nativeAbiLevel(): Int
+
+    fun isAvailable(): Boolean = loaded
+
+    fun spawn(command: List<String>): Int? {
+        if (!loaded) return null
+        return runCatching { nativeSpawn(command.toTypedArray()) }
+            .getOrNull()
+            ?.takeIf { it > 0 }
+    }
+}
