@@ -0,0 +1,94 @@
+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.ComponentName
+import android.content.Context
+import android.content.Intent
+import android.content.pm.PackageManager
+import android.os.Bundle
+import android.os.ResultReceiver
+import dagger.hilt.android.qualifiers.ApplicationContext
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchExecutor
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchResult
+import de.szalkowski.activitylauncher.domain.launcher.ShortcutCreator
+import de.szalkowski.activitylauncher.domain.launcher.SignedPluginContract
+import de.szalkowski.activitylauncher.domain.model.ActivityLaunchBackend
+import java.util.concurrent.CountDownLatch
+import java.util.concurrent.TimeUnit
+import java.util.concurrent.atomic.AtomicReference
+import javax.inject.Inject
+
+/** Sends an explicit target to an installed, same-signature Root Activity Launcher plugin. */
+class RootPluginActivityLaunchExecutor @Inject constructor(
+    @ApplicationContext private val context: Context,
+) : ActivityLaunchExecutor {
+    override val backend: ActivityLaunchBackend = ActivityLaunchBackend.ROOT_PLUGIN
+
+    override fun isAvailable(): Boolean = findPlugin() != null
+
+    override fun launch(intent: Intent): ActivityLaunchResult {
+        val target = intent.component
+            ?: return ActivityLaunchResult(false, "Root plugin requires an explicit component")
+        val plugin = findPlugin()
+            ?: return ActivityLaunchResult(false, "Signed Root Activity Launcher plugin is not installed")
+
+        return runCatching {
+            val completed = CountDownLatch(1)
+            val response = AtomicReference<ActivityLaunchResult>()
+            val receiver = object : ResultReceiver(null) {
+                override fun onReceiveResult(resultCode: Int, resultData: Bundle?) {
+                    response.set(
+                        ActivityLaunchResult(
+                            started = resultCode == SignedPluginContract.RESULT_STARTED,
+                            message = resultData
+                                ?.getString(SignedPluginContract.EXTRA_RESULT_MESSAGE),
+                        ),
+                    )
+                    completed.countDown()
+                }
+            }
+            val pluginIntent = Intent(SignedPluginContract.ACTION_LAUNCH).apply {
+                component = plugin
+                putExtra(ShortcutCreator.INTENT_EXTRA_INTENT, intent.toUri(Intent.URI_INTENT_SCHEME))
+                putExtra(SignedPluginContract.EXTRA_API_VERSION, SignedPluginContract.API_VERSION)
+                putExtra(SignedPluginContract.EXTRA_RESULT_RECEIVER, receiver)
+                putExtra(EXTRA_TARGET_COMPONENT, target.flattenToString())
+                addFlags(Intent.FLAG_ACTIVITY_NEW_TASK)
+            }
+            context.startActivity(pluginIntent)
+            if (!completed.await(PLUGIN_TIMEOUT_SECONDS, TimeUnit.SECONDS)) {
+                ActivityLaunchResult(false, "Root plugin did not return a result")
+            } else {
+                response.get() ?: ActivityLaunchResult(false, "Root plugin returned an empty result")
+            }
+        }.getOrElse { error ->
+            ActivityLaunchResult(false, error.message ?: error::class.java.simpleName)
+        }
+    }
+
+    private fun findPlugin(): ComponentName? {
+        val packageManager = context.packageManager
+
+        @Suppress("DEPRECATION")
+        val handlers = packageManager.queryIntentActivities(
+            Intent(SignedPluginContract.ACTION_LAUNCH).setPackage(ROOT_PLUGIN_PACKAGE),
+            0,
+        )
+        return handlers.asSequence()
+            .filter { handler ->
+                val packageName = handler.activityInfo.packageName
+                handler.activityInfo.permission == SignedPluginContract.PERMISSION &&
+                    packageManager.checkPermission(SignedPluginContract.PERMISSION, packageName) ==
+                    PackageManager.PERMISSION_GRANTED &&
+                    packageManager.checkSignatures(context.packageName, packageName) ==
+                    PackageManager.SIGNATURE_MATCH
+            }
+            .map { ComponentName(it.activityInfo.packageName, it.activityInfo.name) }
+            .firstOrNull()
+    }
+
+    companion object {
+        const val EXTRA_TARGET_COMPONENT = "activitylauncher.root_plugin_target"
+        const val ROOT_PLUGIN_PACKAGE = "de.szalkowski.activitylauncher.rootplugin"
+        private const val PLUGIN_TIMEOUT_SECONDS = 45L
+    }
+}
