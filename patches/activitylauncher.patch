+package de.szalkowski.activitylauncher.data.launcher
+
+/** Explicit, app-local native diagnostics; it does not hook or inspect other processes. */
+object NativeDiagnostics {
+    private val loaded: Boolean by lazy {
+        runCatching {
+            System.loadLibrary("activitylauncher_worker")
+            true
+        }.getOrDefault(false)
+    }
+
+    @JvmStatic
+    private external fun nativeRecord(event: String, value: String): Long
+
+    @JvmStatic
+    private external fun nativeResolveOwnSymbol(): Int
+
+    @JvmStatic
+    private external fun nativeFallbackSelfTest(): Boolean
+
+    fun record(event: String, value: String): Long {
+        if (!loaded || event.length > MAX_FIELD_LENGTH || value.length > MAX_FIELD_LENGTH) return -1L
+        return runCatching { nativeRecord(event, value) }.getOrDefault(-1L)
+    }
+
+    fun resolveOwnSymbol(): Boolean {
+        return loaded && runCatching { nativeResolveOwnSymbol() == 1 }.getOrDefault(false)
+    }
+
+    fun fallbackSelfTest(): Boolean {
+        return loaded && runCatching { nativeFallbackSelfTest() }.getOrDefault(false)
+    }
+
+    private const val MAX_FIELD_LENGTH = 256
+}
