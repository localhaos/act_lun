+package de.szalkowski.activitylauncher.data.permissions
+
+import android.content.Context
+import android.content.pm.PackageManager
+import android.content.pm.PermissionInfo
+import android.os.Build
+import android.util.Log
+import androidx.core.content.ContextCompat
+import dagger.hilt.android.qualifiers.ApplicationContext
+import de.szalkowski.activitylauncher.data.launcher.ShizukuCommandExecutor
+import de.szalkowski.activitylauncher.data.launcher.ShizukuState
+import rikka.shizuku.Shizuku
+import java.util.concurrent.atomic.AtomicBoolean
+import javax.inject.Inject
+import javax.inject.Singleton
+
+internal fun isRuntimeDangerousPermission(protectionLevel: Int): Boolean =
+    protectionLevel and PermissionInfo.PROTECTION_MASK_BASE == PermissionInfo.PROTECTION_DANGEROUS
+
+enum class ShizukuInstallation {
+    STANDARD,
+    COMPATIBLE_MANAGER,
+    BINDER_ONLY,
+    NONE,
+}
+
+/** Detects both the standard manager and compatible Shizuku-derived binder providers. */
+@Singleton
+class ShizukuManagerDetector @Inject constructor(
+    @ApplicationContext private val context: Context,
+) {
+    fun detect(): ShizukuInstallation = when {
+        isInstalled(STANDARD_PACKAGE) -> ShizukuInstallation.STANDARD
+        isInstalled(COMPATIBLE_PACKAGE) -> ShizukuInstallation.COMPATIBLE_MANAGER
+        runCatching { Shizuku.pingBinder() }.getOrDefault(false) -> ShizukuInstallation.BINDER_ONLY
+        else -> ShizukuInstallation.NONE
+    }
+
+    @Suppress("DEPRECATION")
+    private fun isInstalled(packageName: String): Boolean = runCatching {
+        context.packageManager.getPackageInfo(packageName, 0)
+    }.isSuccess
+
+    private companion object {
+        const val STANDARD_PACKAGE = "moe.shizuku.privileged.api"
+        const val COMPATIBLE_PACKAGE = "moe.shizuku.manager"
+    }
+}
+
+/**
+ * Coordinates startup permission prompts without requesting hidden, signature, or system-only
+ * permissions. Shizuku authorization is always delegated to the official Shizuku API.
+ */
+@Singleton
+class StartupPermissionCoordinator @Inject constructor(
+    @ApplicationContext private val context: Context,
+    private val shizukuCommandExecutor: ShizukuCommandExecutor,
+    private val shizukuManagerDetector: ShizukuManagerDetector,
+) {
+    private val started = AtomicBoolean(false)
+    private val runtimeRequestPending = AtomicBoolean(false)
+    private val shizukuRequestStarted = AtomicBoolean(false)
+    private val binderReceivedListener = Shizuku.OnBinderReceivedListener {
+        requestShizukuIfReady()
+    }
+
+    fun start(requestRuntimePermissions: (Array<String>) -> Unit) {
+        if (!started.compareAndSet(false, true)) return
+
+        val missingPermissions = missingRuntimePermissions()
+        if (missingPermissions.isNotEmpty()) {
+            runtimeRequestPending.set(true)
+            requestRuntimePermissions(missingPermissions)
+        }
+
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
+            runCatching { Shizuku.addBinderReceivedListenerSticky(binderReceivedListener) }
+                .onFailure { Log.w(TAG, "Could not register Shizuku binder listener", it) }
+            requestShizukuIfReady()
+        }
+    }
+
+    fun onRuntimePermissionRequestFinished() {
+        runtimeRequestPending.set(false)
+        requestShizukuIfReady()
+    }
+
+    fun stop() {
+        if (!started.compareAndSet(true, false)) return
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
+            runCatching { Shizuku.removeBinderReceivedListener(binderReceivedListener) }
+        }
+    }
+
+    @Suppress("DEPRECATION")
+    internal fun missingRuntimePermissions(): Array<String> {
+        if (Build.VERSION.SDK_INT < Build.VERSION_CODES.M) return emptyArray()
+
+        val packageInfo = runCatching {
+            context.packageManager.getPackageInfo(context.packageName, PackageManager.GET_PERMISSIONS)
+        }.getOrNull() ?: return emptyArray()
+
+        return packageInfo.requestedPermissions.orEmpty()
+            .asSequence()
+            .filterNot { it in SHIZUKU_PERMISSIONS }
+            .filter { permission ->
+                ContextCompat.checkSelfPermission(context, permission) != PackageManager.PERMISSION_GRANTED
+            }
+            .filter { permission ->
+                val info = runCatching {
+                    context.packageManager.getPermissionInfo(permission, 0)
+                }.getOrNull()
+                info != null && isRuntimeDangerousPermission(info.protectionLevel)
+            }
+            .distinct()
+            .sorted()
+            .toList()
+            .toTypedArray()
+    }
+
+    private fun requestShizukuIfReady() {
+        if (!started.get() || runtimeRequestPending.get()) return
+        if (shizukuCommandExecutor.state() != ShizukuState.DENIED) return
+        if (!shizukuRequestStarted.compareAndSet(false, true)) return
+
+        val installation = shizukuManagerDetector.detect()
+        Log.i(TAG, "Requesting Shizuku authorization from $installation")
+        shizukuCommandExecutor.requestPermission { granted ->
+            Log.i(TAG, "Shizuku authorization result: ${if (granted) "granted" else "not granted"}")
+        }
+    }
+
+    private companion object {
+        const val TAG = "StartupPermissions"
+        val SHIZUKU_PERMISSIONS = setOf(
+            "moe.shizuku.manager.permission.API_V23",
+            "moe.shizuku.privileged.api.PERMISSION_GRANTED",
+        )
+    }
+}
diff --git a/app/src/main/java/de/szalkowski/activitylauncher/data/plugin/SignedPluginLoader.kt b/app/src/main/java/de/szalkowski/activitylauncher/data/plugin/SignedPluginLoader.kt
