+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.Intent
+import de.szalkowski.activitylauncher.core.util.ActivityCommandBuilder
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchExecutor
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchResult
+import de.szalkowski.activitylauncher.domain.model.ActivityLaunchBackend
+import javax.inject.Inject
+
+/**
+ * Starts the platform activity-manager command through the Java runtime.
+ * This backend has the application's UID and therefore does not bypass Android permissions.
+ */
+class JvmActivityLaunchExecutor @Inject constructor() : ActivityLaunchExecutor {
+    override val backend: ActivityLaunchBackend = ActivityLaunchBackend.JVM
+
+    override fun isAvailable(): Boolean = true
+
+    override fun launch(intent: Intent): ActivityLaunchResult {
+        return runCatching {
+            Runtime.getRuntime().exec(ActivityCommandBuilder.buildStartCommand(intent).toTypedArray())
+        }.fold(
+            onSuccess = { process ->
+                process.outputStream.close()
+                ActivityLaunchResult(started = true)
+            },
+            onFailure = { error ->
+                ActivityLaunchResult(
+                    started = false,
+                    message = error.message ?: error::class.java.simpleName,
+                )
+            },
+        )
+    }
+}
