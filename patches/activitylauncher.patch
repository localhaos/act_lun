+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.ComponentName
+import android.os.Process
+import de.szalkowski.activitylauncher.core.util.PackageStateCommandBuilder
+import javax.inject.Inject
+
+class RootPackageStateExecutor @Inject constructor(
+    private val commandExecutor: RootCommandExecutor,
+) {
+    constructor() : this(RootCommandExecutor())
+
+    fun isAvailable(): Boolean = commandExecutor.isAvailable()
+
+    fun setActivityEnabled(componentName: ComponentName, enabled: Boolean): PackageStateChangeResult {
+        return runCatching {
+            val command = PackageStateCommandBuilder.buildActivityCommand(
+                componentName,
+                enabled,
+                Process.myUid() / PER_USER_RANGE,
+            )
+            val result = commandExecutor.execute(command)
+            PackageStateChangeResult(
+                success = result.succeeded,
+                message = result.message,
+            )
+        }.getOrElse { error ->
+            PackageStateChangeResult(false, error.message ?: error::class.java.simpleName)
+        }
+    }
+
+    private companion object {
+        const val PER_USER_RANGE = 100_000
+    }
+}
