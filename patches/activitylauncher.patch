+package de.szalkowski.activitylauncher.rootplugin;
+
+import android.app.Activity;
+import android.content.ComponentName;
+import android.content.Intent;
+import android.os.Bundle;
+import android.os.ResultReceiver;
+import android.widget.Toast;
+
+import java.io.BufferedReader;
+import java.io.File;
+import java.io.InputStreamReader;
+import java.util.ArrayList;
+import java.util.Arrays;
+import java.util.List;
+import java.util.regex.Pattern;
+import java.util.concurrent.atomic.AtomicBoolean;
+
+public final class RootLaunchPluginActivity extends Activity {
+    private static final String EXTRA_INTENT = "intent";
+    private static final String EXTRA_API_VERSION = "activitylauncher.plugin_api_version";
+    private static final String EXTRA_RESULT_RECEIVER = "activitylauncher.plugin_result_receiver";
+    private static final String EXTRA_RESULT_MESSAGE = "activitylauncher.plugin_result_message";
+    private static final int RESULT_FAILED = 0;
+    private static final int RESULT_STARTED = 1;
+    private static final int SUPPORTED_API_VERSION = 2;
+    private static final int MAX_INTENT_URI_LENGTH = 16_384;
+    private static final Pattern PACKAGE_NAME =
+            Pattern.compile("[A-Za-z][A-Za-z0-9_]*(?:\\.[A-Za-z0-9_]+)*");
+    private static final Pattern CLASS_NAME = Pattern.compile("[A-Za-z_$][A-Za-z0-9_$.]*");
+    private static final Pattern ACTION_NAME = Pattern.compile("[A-Za-z][A-Za-z0-9_.]*");
+    private static final List<String> SU_CANDIDATES = Arrays.asList(
+            "/system/bin/su",
+            "/system/xbin/su",
+            "/sbin/su",
+            "/su/bin/su",
+            "/debug_ramdisk/su");
+    private static final List<String> TOYBOX_CANDIDATES = Arrays.asList(
+            "/system/bin/toybox",
+            "/system/xbin/toybox",
+            "/vendor/bin/toybox");
+
+    private final AtomicBoolean resultSent = new AtomicBoolean(false);
+    private ResultReceiver resultReceiver;
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        final Intent request = getIntent();
+        if (request != null) {
+            resultReceiver = request.getParcelableExtra(EXTRA_RESULT_RECEIVER);
+        }
+        new Thread(() -> processRequest(request), "activitylauncher-root-plugin").start();
+    }
+
+    private void processRequest(Intent request) {
+        try {
+            if (request == null || request.getIntExtra(EXTRA_API_VERSION, -1) != SUPPORTED_API_VERSION) {
+                finishWithError("unsupported plugin API");
+                return;
+            }
+            String uri = request.getStringExtra(EXTRA_INTENT);
+            if (uri == null || uri.isEmpty() || uri.length() > MAX_INTENT_URI_LENGTH) {
+                finishWithError("invalid target data");
+                return;
+            }
+            Intent target = Intent.parseUri(uri, Intent.URI_INTENT_SCHEME);
+            ComponentName component = target.getComponent();
+            if (!isValidComponent(component)) {
+                finishWithError("invalid or implicit target component");
+                return;
+            }
+
+            List<String> command = new ArrayList<>();
+            command.add("/system/bin/am");
+            command.add("start");
+            command.add("-W");
+            command.add("--user");
+            command.add("current");
+            if (target.getFlags() != 0) {
+                command.add("-f");
+                command.add("0x" + Integer.toHexString(target.getFlags()));
+            }
+            String action = target.getAction();
+            if (action != null && ACTION_NAME.matcher(action).matches()) {
+                command.add("-a");
+                command.add(action);
+            }
+            command.add("-n");
+            command.add(component.flattenToString());
+
+            CommandResult result = executeRoot(command);
+            if (result.exitCode == 0) {
+                finishWithToast(getString(R.string.launch_success, result.strategy), true);
+            } else {
+                String detail = result.output.isEmpty()
+                        ? "exit " + result.exitCode
+                        : result.output;
+                finishWithError(detail);
+            }
+        } catch (Throwable error) {
+            String message = error.getMessage();
+            finishWithError(message == null ? error.getClass().getSimpleName() : message);
+        }
+    }
+
+    private CommandResult executeRoot(List<String> command) throws Exception {
+        String su = firstExecutable(SU_CANDIDATES);
+        if (su == null) {
+            return new CommandResult(126, "root manager not found", "unavailable");
+        }
+
+        List<Attempt> attempts = new ArrayList<>();
+        List<String> withSeparator = new ArrayList<>(Arrays.asList(su, "0", "--"));
+        withSeparator.addAll(command);
+        attempts.add(new Attempt("su user separator", withSeparator));
+
+        List<String> direct = new ArrayList<>(Arrays.asList(su, "0"));
+        direct.addAll(command);
+        attempts.add(new Attempt("su user direct", direct));
+
+        attempts.add(new Attempt(
+                "su command",
+                Arrays.asList(su, "-c", toShellCommand(command))));
+
+        String toybox = firstExecutable(TOYBOX_CANDIDATES);
+        if (toybox != null) {
+            List<String> viaToybox = new ArrayList<>(Arrays.asList(su, "0", "--", toybox, "env"));
+            viaToybox.addAll(command);
+            attempts.add(new Attempt("system toybox", viaToybox));
+        }
+
+        CommandResult last = null;
+        for (Attempt attempt : attempts) {
+            last = runProcess(attempt);
+            if (last.exitCode == 0) {
+                return last;
+            }
+        }
+        return last == null ? new CommandResult(127, "no root strategy", "unavailable") : last;
+    }
+
+    private CommandResult runProcess(Attempt attempt) throws Exception {
+        Process process = new ProcessBuilder(attempt.arguments).redirectErrorStream(true).start();
+        process.getOutputStream().close();
+        StringBuilder output = new StringBuilder();
+        try (BufferedReader reader = new BufferedReader(new InputStreamReader(process.getInputStream()))) {
+            String line;
+            while ((line = reader.readLine()) != null) {
+                if (output.length() < 4_096) {
+                    if (output.length() > 0) output.append('\n');
+                    int remaining = 4_096 - output.length();
+                    output.append(line, 0, Math.min(line.length(), remaining));
+                }
+            }
+        }
+        int exitCode = process.waitFor();
+        return new CommandResult(exitCode, output.toString().trim(), attempt.name);
+    }
+
+    private boolean isValidComponent(ComponentName component) {
+        return component != null
+                && PACKAGE_NAME.matcher(component.getPackageName()).matches()
+                && CLASS_NAME.matcher(component.getClassName()).matches();
+    }
+
+    private String firstExecutable(List<String> candidates) {
+        for (String candidate : candidates) {
+            if (new File(candidate).canExecute()) return candidate;
+        }
+        return null;
+    }
+
+    private String toShellCommand(List<String> command) {
+        StringBuilder result = new StringBuilder();
+        for (String argument : command) {
+            if (result.length() > 0) result.append(' ');
+            result.append('\'')
+                    .append(argument.replace("'", "'\"'\"'"))
+                    .append('\'');
+        }
+        return result.toString();
+    }
+
+    private void finishWithError(String detail) {
+        finishWithToast(getString(R.string.launch_failed, detail), false);
+    }
+
+    private void finishWithToast(String message, boolean started) {
+        if (resultReceiver != null && resultSent.compareAndSet(false, true)) {
+            Bundle result = new Bundle();
+            result.putString(EXTRA_RESULT_MESSAGE, message);
+            resultReceiver.send(started ? RESULT_STARTED : RESULT_FAILED, result);
+        }
+        runOnUiThread(() -> {
+            Toast.makeText(this, message, Toast.LENGTH_LONG).show();
+            finish();
+        });
+    }
+
+    private static final class Attempt {
+        final String name;
+        final List<String> arguments;
+
+        Attempt(String name, List<String> arguments) {
+            this.name = name;
+            this.arguments = arguments;
+        }
+    }
+
+    private static final class CommandResult {
+        final int exitCode;
+        final String output;
+        final String strategy;
+
+        CommandResult(int exitCode, String output, String strategy) {
+            this.exitCode = exitCode;
+            this.output = output;
+            this.strategy = strategy;
+        }
+    }
+}
