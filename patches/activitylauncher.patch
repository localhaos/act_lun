+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.Intent
+import de.szalkowski.activitylauncher.core.util.ActivityCommandBuilder
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchExecutor
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchResult
+import de.szalkowski.activitylauncher.domain.model.ActivityLaunchBackend
+import javax.inject.Inject
+import kotlin.concurrent.thread
+
+enum class ShizukuState {
+    UNSUPPORTED,
+    STOPPED,
+    DENIED,
+    GRANTED,
+}
+
+/**
+ * Shizuku-backed activity launcher. It sends an argument vector to `am` directly and never
+ * invokes `sh -c`, so component names and extras cannot become shell syntax.
+ */
+class ShizukuActivityLaunchExecutor @Inject constructor(
+    private val commandExecutor: ShizukuCommandExecutor,
+) : ActivityLaunchExecutor {
+    constructor() : this(ShizukuCommandExecutor())
+
+    override val backend: ActivityLaunchBackend = ActivityLaunchBackend.SHIZUKU_PLUS
+
+    override fun isAvailable(): Boolean = commandExecutor.isAvailable()
+
+    fun state(): ShizukuState = commandExecutor.state()
+
+    fun hasPermission(): Boolean = commandExecutor.hasPermission()
+
+    fun requestPermission(callback: (Boolean) -> Unit) = commandExecutor.requestPermission(callback)
+
+    override fun launch(intent: Intent): ActivityLaunchResult {
+        when (val shizukuState = state()) {
+            ShizukuState.UNSUPPORTED -> return ActivityLaunchResult(false, "Shizuku wymaga Androida 7.0 lub nowszego")
+            ShizukuState.STOPPED -> return ActivityLaunchResult(false, "Usługa Shizuku nie działa")
+            ShizukuState.DENIED -> return ActivityLaunchResult(false, "Brak zgody Shizuku")
+            ShizukuState.GRANTED -> Unit
+        }
+
+        return runCatching {
+            val command = ActivityCommandBuilder.buildStartCommand(intent)
+            thread(start = true, isDaemon = true, name = "activitylauncher-shizuku-process") {
+                runCatching { commandExecutor.execute(command) }
+            }
+            ActivityLaunchResult(started = true)
+        }.getOrElse { error ->
+            ActivityLaunchResult(
+                started = false,
+                message = error.message ?: error::class.java.simpleName,
+            )
+        }
+    }
+}
diff --git a/app/src/main/java/de/szalkowski/activitylauncher/data/launcher/ShizukuCommandExecutor.kt b/app/src/main/java/de/szalkowski/activitylauncher/data/launcher/ShizukuCommandExecutor.kt
