diff --git a/app/src/main/cpp/activitylauncher_diagnostics.cpp b/app/src/main/cpp/activitylauncher_diagnostics.cpp
new file mode 100644
index 0000000..f3686c0
--- /dev/null
+++ b/app/src/main/cpp/activitylauncher_diagnostics.cpp
@@ -0,0 +1,128 @@
+#include "activitylauncher_wrapper.h"
+
+#include <jni.h>
+
+#include <cerrno>
+#include <cstring>
+#include <dlfcn.h>
+
+namespace activitylauncher {
+namespace {
+constexpr const char* kOwnLibrary = "libactivitylauncher_worker.so";
+constexpr int kFallback = -ENOENT;
+
+ActivityLauncherWrapper& instance() noexcept {
+    static ActivityLauncherWrapper wrapper;
+    return wrapper;
+}
+}  // namespace
+
+bool ActivityLauncherWrapper::validField(const std::string& value) noexcept {
+    return !value.empty() && value.size() <= kMaxFieldLength &&
+           value.find('\0') == std::string::npos;
+}
+
+uint64_t ActivityLauncherWrapper::anonymizedHash(const std::string& value) noexcept {
+    // FNV-1a is an anonymized telemetry label, never an authentication primitive.
+    uint64_t hash = 1469598103934665603ULL;
+    for (unsigned char byte : value) {
+        hash ^= byte;
+        hash *= 1099511628211ULL;
+    }
+    return hash;
+}
+
+int64_t ActivityLauncherWrapper::record(std::string event, std::string value) noexcept {
+    if (!validField(event) || !validField(value)) return kFallback;
+    const uint64_t eventHash = anonymizedHash(event);
+    const uint64_t valueHash = anonymizedHash(value);
+    {
+        std::lock_guard<std::mutex> lock(mutex_);
+        // Raw values are deliberately not retained or logged.
+        (void)eventHash;
+        (void)valueHash;
+        eventCount_.fetch_add(1, std::memory_order_relaxed);
+    }
+    return eventCount_.load(std::memory_order_relaxed);
+}
+
+int ActivityLauncherWrapper::resolveSymbol(const char* symbolName, int fallback) noexcept {
+    if (symbolName == nullptr || std::strlen(symbolName) == 0) return fallback;
+
+    dlerror();
+    void* handle = dlopen(kOwnLibrary, RTLD_NOW | RTLD_LOCAL);
+    const char* openError = dlerror();
+    if (handle == nullptr || openError != nullptr) {
+        if (handle != nullptr) dlclose(handle);
+        return fallback;
+    }
+
+    dlerror();
+    void* symbol = dlsym(handle, symbolName);
+    const char* lookupError = dlerror();
+    if (symbol == nullptr || lookupError != nullptr) {
+        dlclose(handle);
+        return fallback;
+    }
+
+    using DiagnosticFunction = int (*)();
+    const int result = reinterpret_cast<DiagnosticFunction>(symbol)();
+    dlclose(handle);
+    return result;
+}
+
+int ActivityLauncherWrapper::resolveOwnSymbol() noexcept {
+    return resolveSymbol("activitylauncher_diagnostic_ping", kFallback);
+}
+
+bool ActivityLauncherWrapper::fallbackSelfTest() noexcept {
+    return resolveSymbol("activitylauncher_symbol_that_does_not_exist", kFallback) == kFallback;
+}
+
+}  // namespace activitylauncher
+
+extern "C" __attribute__((visibility("default"))) int activitylauncher_diagnostic_ping() {
+    return 1;
+}
+
+extern "C" JNIEXPORT jlong JNICALL
+Java_de_szalkowski_activitylauncher_data_launcher_NativeDiagnostics_nativeRecord(
+    JNIEnv* env,
+    jclass,
+    jstring event,
+    jstring value
+) {
+    if (env == nullptr || event == nullptr || value == nullptr) return -EINVAL;
+    const char* eventChars = env->GetStringUTFChars(event, nullptr);
+    const char* valueChars = env->GetStringUTFChars(value, nullptr);
+    if (eventChars == nullptr || valueChars == nullptr) {
+        if (eventChars != nullptr) env->ReleaseStringUTFChars(event, eventChars);
+        if (valueChars != nullptr) env->ReleaseStringUTFChars(value, valueChars);
+        return -EINVAL;
+    }
+    const jsize eventLength = env->GetStringUTFLength(event);
+    const jsize valueLength = env->GetStringUTFLength(value);
+    const bool valid = eventLength > 0 && eventLength <= 256 && valueLength > 0 && valueLength <= 256;
+    const jlong result = valid
+        ? activitylauncher::instance().record(eventChars, valueChars)
+        : static_cast<jlong>(-EINVAL);
+    env->ReleaseStringUTFChars(event, eventChars);
+    env->ReleaseStringUTFChars(value, valueChars);
+    return result;
+}
+
+extern "C" JNIEXPORT jint JNICALL
+Java_de_szalkowski_activitylauncher_data_launcher_NativeDiagnostics_nativeResolveOwnSymbol(
+    JNIEnv*,
+    jclass
+) {
+    return activitylauncher::instance().resolveOwnSymbol();
+}
+
+extern "C" JNIEXPORT jboolean JNICALL
+Java_de_szalkowski_activitylauncher_data_launcher_NativeDiagnostics_nativeFallbackSelfTest(
+    JNIEnv*,
+    jclass
+) {
+    return activitylauncher::instance().fallbackSelfTest() ? JNI_TRUE : JNI_FALSE;
+}
