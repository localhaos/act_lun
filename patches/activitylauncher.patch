+                packageRepository.isActivityEnabled(activity.componentName) == true
+            }
+            val result = if (commandResult.success && !enabled) {
+                PackageStateChangeResult(
+                    false,
+                    "The component is still disabled; its application may also be disabled",
+                )
+            } else {
+                commandResult
+            }
+            if (enabled) {
+                combinedActivities = combinedActivities.map { candidate ->
+                    if (candidate.componentName == activity.componentName) {
+                        candidate.copy(isEnabled = true)
+                    } else {
+                        candidate
+                    }
+                }
+                allPackageActivities = allPackageActivities?.let { current ->
+                    current.copy(
+                        defaultActivity = current.defaultActivity?.let { defaultActivity ->
+                            combinedActivities.find { it.componentName == defaultActivity.componentName }
+                        },
+                        activities = combinedActivities,
+                    )
