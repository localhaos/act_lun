@@ -0,0 +1,135 @@
+package de.szalkowski.activitylauncher.data.plugin
+
+import android.content.Context
+import android.content.pm.PackageManager
+import android.content.pm.Signature
+import android.os.Build
+import dalvik.system.DexClassLoader
+import de.szalkowski.activitylauncher.domain.plugin.ActivityLauncherPlugin
+import java.io.File
+import java.io.FileInputStream
+import java.io.FileOutputStream
+import java.security.MessageDigest
+import javax.inject.Inject
+
+/** Loads only same-signature APKs and only classes implementing ActivityLauncherPlugin. */
+class SignedPluginLoader @Inject constructor() {
+    fun load(context: Context, apk: File, className: String): Result<ActivityLauncherPlugin> {
+        return runCatching {
+            require(apk.isFile && apk.length() in 1..MAX_APK_BYTES) { "Invalid plugin APK" }
+            require(className.isNotBlank() && className.length <= MAX_CLASS_NAME_LENGTH) {
+                "Invalid plugin class name"
+            }
+            require(hasSameSigningCertificate(context, apk)) { "Plugin signature is not trusted" }
+
+            val pluginDir = File(context.cacheDir, "signed_plugins").apply { mkdirs() }
+            val copiedApk = File(pluginDir, "plugin-${sha256(apk)}.apk")
+            if (!copiedApk.isFile || copiedApk.length() != apk.length()) {
+                copyBounded(apk, copiedApk)
+            }
+            val optimizedDir = File(pluginDir, "optimized").apply { mkdirs() }
+            val classLoader = DexClassLoader(
+                copiedApk.absolutePath,
+                optimizedDir.absolutePath,
+                null,
+                context.classLoader,
+            )
+            val clazz = Class.forName(className, true, classLoader)
+            require(ActivityLauncherPlugin::class.java.isAssignableFrom(clazz)) {
+                "Plugin class does not implement ActivityLauncherPlugin"
+            }
+            @Suppress("UNCHECKED_CAST")
+            val plugin = clazz.getDeclaredConstructor().newInstance() as ActivityLauncherPlugin
+            plugin.onLoad(context)
+            plugin
+        }
+    }
+
+    private fun copyBounded(source: File, destination: File) {
+        val temporary = File(destination.parentFile, "${destination.name}.tmp")
+        try {
+            FileInputStream(source).use { input ->
+                FileOutputStream(temporary).use { output ->
+                    val buffer = ByteArray(BUFFER_SIZE)
+                    var copied = 0L
+                    while (true) {
+                        val count = input.read(buffer)
+                        if (count < 0) break
+                        copied += count
+                        require(copied <= MAX_APK_BYTES) { "Plugin APK is too large" }
+                        output.write(buffer, 0, count)
+                    }
+                    output.fd.sync()
+                }
+            }
+            require(temporary.length() == source.length()) { "Plugin APK copy is incomplete" }
+            if (!temporary.renameTo(destination)) {
+                throw IllegalStateException("Cannot finalize plugin APK copy")
+            }
+        } finally {
+            temporary.delete()
+        }
+    }
+
+    private fun hasSameSigningCertificate(context: Context, apk: File): Boolean {
+        val archive = packageInfo(context.packageManager, apk.absolutePath) ?: return false
+        val app = appPackageInfo(context.packageManager, context.packageName) ?: return false
+        val archiveSignatures = signatures(archive)
+        val appSignatures = signatures(app)
+        return archiveSignatures.isNotEmpty() && archiveSignatures.toSet() == appSignatures.toSet()
+    }
+
+    private fun packageInfo(pm: PackageManager, path: String): android.content.pm.PackageInfo? {
+        @Suppress("DEPRECATION")
+        val flags = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.P) {
+            PackageManager.GET_SIGNING_CERTIFICATES
+        } else {
+            PackageManager.GET_SIGNATURES
+        }
+        return pm.getPackageArchiveInfo(path, flags)
+    }
+
+    private fun appPackageInfo(pm: PackageManager, packageName: String): android.content.pm.PackageInfo? {
+        @Suppress("DEPRECATION")
+        val flags = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.P) {
+            PackageManager.GET_SIGNING_CERTIFICATES
+        } else {
+            PackageManager.GET_SIGNATURES
+        }
+        return pm.getPackageInfo(packageName, flags)
+    }
+
+    private fun signatures(info: android.content.pm.PackageInfo): Set<ByteArrayKey> {
+        val values: Array<out Signature> = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.P) {
+            info.signingInfo?.apkContentsSigners.orEmpty()
+        } else {
+            @Suppress("DEPRECATION")
+            info.signatures.orEmpty()
+        }
+        return values.map { ByteArrayKey(it.toByteArray()) }.toSet()
+    }
+
+    private fun sha256(file: File): String {
+        val digest = MessageDigest.getInstance("SHA-256")
+        FileInputStream(file).use { input ->
+            val buffer = ByteArray(BUFFER_SIZE)
+            while (true) {
+                val count = input.read(buffer)
+                if (count < 0) break
+                digest.update(buffer, 0, count)
+            }
+        }
+        return digest.digest().joinToString("") { "%02x".format(it) }
+    }
+
+    private data class ByteArrayKey(val bytes: ByteArray) {
+        override fun equals(other: Any?): Boolean = other is ByteArrayKey && bytes.contentEquals(other.bytes)
+        override fun hashCode(): Int = bytes.contentHashCode()
+    }
+
+    companion object {
+        private const val BUFFER_SIZE = 8192
+        private const val MAX_APK_BYTES = 50L * 1024L * 1024L
+        private const val MAX_CLASS_NAME_LENGTH = 256
+    }
+}
