+    fun launchWithBackend(backend: ActivityLaunchBackend) {
+        val info = getEditedActivityInfo()
+        launchActivityUseCase(
+            LaunchRequest(
+                intent = getActivityIntent(info.componentName, Bundle()),
+                backend = backend,
+            ),
+        )
+    }
+
+    fun getEditedActivityIntent() = getActivityIntent(getEditedActivityInfo().componentName, Bundle())
+
+    fun setActivityEnabled(enabled: Boolean) {
+        val target = getEditedActivityInfo().componentName
+        when (shizukuExecutor.state()) {
+            ShizukuState.GRANTED -> executeActivityStateChange(target, enabled, useShizuku = true)
+            ShizukuState.DENIED -> {
+                if (rootPackageStateExecutor.isAvailable()) {
+                    executeActivityStateChange(target, enabled, useShizuku = false)
+                } else {
+                    shizukuExecutor.requestPermission { granted ->
+                        viewModelScope.launch {
+                            if (granted) {
+                                executeActivityStateChange(target, enabled, useShizuku = true)
+                            } else {
+                                _errorMessage.emit(R.string.error_shizuku_permission)
+                            }
+                        }
+                    }
+                }
+            }
+            ShizukuState.STOPPED -> viewModelScope.launch {
+                if (rootPackageStateExecutor.isAvailable()) {
+                    executeActivityStateChange(target, enabled, useShizuku = false)
+                } else {
+                    _errorMessage.emit(R.string.error_shizuku_not_running)
+                }
+            }
+            ShizukuState.UNSUPPORTED -> viewModelScope.launch {
+                if (rootPackageStateExecutor.isAvailable()) {
+                    executeActivityStateChange(target, enabled, useShizuku = false)
+                } else {
+                    _errorMessage.emit(R.string.error_shizuku_unsupported)
+                }
+            }
+        }
+    }
+
+    private fun executeActivityStateChange(
+        componentName: ComponentName,
+        enabled: Boolean,
+        useShizuku: Boolean,
+    ) {
+        viewModelScope.launch(Dispatchers.IO) {
+            val primary = if (useShizuku) {
+                packageStateExecutor.setActivityEnabled(componentName, enabled)
+            } else {
+                rootPackageStateExecutor.setActivityEnabled(componentName, enabled)
+            }
+            val result = if (useShizuku && !primary.success && rootPackageStateExecutor.isAvailable()) {
+                rootPackageStateExecutor.setActivityEnabled(componentName, enabled)
+            } else {
+                primary
+            }
+            if (result.success) {
+                _isActivityEnabled.value = enabled
+                packageRepository.invalidate()
+            }
+            _stateChangeResult.emit(result)
+        }
+    }
