+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.ComponentName
+import android.os.Process
+import de.szalkowski.activitylauncher.core.util.PackageStateCommandBuilder
+import javax.inject.Inject
+
+data class PackageStateChangeResult(
+    val success: Boolean,
+    val message: String? = null,
+)
+
+/** Changes per-user package or component state through the already-authorized Shizuku shell. */
+class ShizukuPackageStateExecutor @Inject constructor(
+    private val commandExecutor: ShizukuCommandExecutor,
+) {
+    constructor() : this(ShizukuCommandExecutor())
+
+    fun setApplicationEnabled(
+        packageName: String,
+        enabled: Boolean,
+        userId: Int = currentUserId(),
+    ): PackageStateChangeResult = runCatching {
+        execute(PackageStateCommandBuilder.buildApplicationCommand(packageName, enabled, userId))
+    }.getOrElse(::failure)
+
+    fun setActivityEnabled(
+        componentName: ComponentName,
+        enabled: Boolean,
+        userId: Int = currentUserId(),
+    ): PackageStateChangeResult = runCatching {
+        execute(PackageStateCommandBuilder.buildActivityCommand(componentName, enabled, userId))
+    }.getOrElse(::failure)
+
+    private fun execute(command: List<String>): PackageStateChangeResult {
+        return runCatching { commandExecutor.execute(command) }
+            .fold(
+                onSuccess = { result ->
+                    PackageStateChangeResult(
+                        success = result.succeeded,
+                        message = result.message,
+                    )
+                },
+                onFailure = ::failure,
+            )
+    }
+
+    private fun failure(error: Throwable): PackageStateChangeResult = PackageStateChangeResult(
+        success = false,
+        message = error.message ?: error::class.java.simpleName,
+    )
+
+    private fun currentUserId(): Int = Process.myUid() / PER_USER_RANGE
+
+    companion object {
+        private const val PER_USER_RANGE = 100_000
+    }
+}
