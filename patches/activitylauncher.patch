index 0000000..87f0d92
--- /dev/null
+++ b/app/src/main/java/de/szalkowski/activitylauncher/data/audit/AuditDetector.kt
@@ -0,0 +1,118 @@
+package de.szalkowski.activitylauncher.data.audit
+
+import de.szalkowski.activitylauncher.domain.audit.AuditFinding
+import de.szalkowski.activitylauncher.domain.audit.AuditFindingType
+import de.szalkowski.activitylauncher.domain.audit.AuditSeverity
+import java.security.MessageDigest
+
+/** Pure detector used by the APK scanner and unit tests. It never returns sensitive literals. */
+object AuditDetector {
+    private val secretCodePattern = Regex("""(?i)\*#\*#([0-9]{2,20})#\*#\*""")
+    private val secretCodeUriPattern = Regex("""(?i)android_secret_code://([0-9]{2,20})""")
+    private val sensitiveAssignmentPattern = Regex(
+        """(?i)\b(password|passwd|passcode|developer[_-]?password|secret(?:[_-]?key)?|api[_-]?key)\b\s*(?:=>|=|:)\s*[\"']?([A-Za-z0-9@#%_+./:-]{4,96})""",
+    )
+    private val sensitiveKeyPattern = Regex(
+        """(?i)\b(password|passwd|passcode|developer[_-]?password|secret[_-]?key|api[_-]?key)\b""",
+    )
+    private val debugMarkers = listOf(
+        "debuggable",
+        "debug",
+        "developer",
+        "engineering",
+        "staging",
+        "internal",
+        "test_only",
+        "testonly",
+        "strictmode",
+        "verbose",
+        "trace",
+        "dump",
+    )
+
+    fun detect(text: String, source: String): List<AuditFinding> {
+        val findings = linkedMapOf<String, AuditFinding>()
+
+        fun add(finding: AuditFinding) {
+            val key = "${finding.type}|${finding.value}|${finding.source}"
+            findings.putIfAbsent(key, finding)
+        }
+
+        secretCodePattern.findAll(text).forEach { match ->
+            val code = match.groupValues[1]
+            add(
+                AuditFinding(
+                    type = AuditFindingType.SECRET_CODE,
+                    severity = AuditSeverity.MEDIUM,
+                    value = "*#*#$code#*#*",
+                    source = source,
+                    details = "Znaleziony wzorzec kodu serwisowego; wymaga weryfikacji odbiornika.",
+                ),
+            )
+        }
+        secretCodeUriPattern.findAll(text).forEach { match ->
+            val code = match.groupValues[1]
+            add(
+                AuditFinding(
+                    type = AuditFindingType.SECRET_CODE,
+                    severity = AuditSeverity.MEDIUM,
+                    value = "android_secret_code://$code",
+                    source = source,
+                    details = "Znaleziony URI secret-code; wymaga weryfikacji odbiornika.",
+                ),
+            )
+        }
+
+        sensitiveAssignmentPattern.findAll(text).forEach { match ->
+            val key = match.groupValues[1]
+            val candidate = match.groupValues[2]
+            add(
+                AuditFinding(
+                    type = AuditFindingType.SENSITIVE_LITERAL,
+                    severity = AuditSeverity.HIGH,
+                    value = key,
+                    source = source,
+                    details = "Wartość ukryta; SHA-256=${sha256(candidate)}",
+                ),
+            )
+        }
+        sensitiveKeyPattern.findAll(text).forEach { match ->
+            val key = match.groupValues[1]
+            add(
+                AuditFinding(
+                    type = AuditFindingType.SENSITIVE_LITERAL,
+                    severity = AuditSeverity.LOW,
+                    value = key,
+                    source = source,
+                    details = "Znaleziono nazwę pola wrażliwego; brak ujawniania wartości.",
+                ),
+            )
+        }
+
+        val lowerText = text.lowercase()
+        debugMarkers.forEach { marker ->
+            if (lowerText.contains(marker)) {
+                add(
+                    AuditFinding(
+                        type = AuditFindingType.DEBUG_MARKER,
+                        severity = if (marker == "debuggable" || marker == "engineering") {
+                            AuditSeverity.MEDIUM
+                        } else {
+                            AuditSeverity.LOW
+                        },
+                        value = marker,
+                        source = source,
+                        details = "Marker diagnostyczny; nie potwierdza samodzielnie trybu debug.",
+                    ),
+                )
+            }
+        }
+
+        return findings.values.toList()
+    }
+
+    private fun sha256(value: String): String {
+        val digest = MessageDigest.getInstance("SHA-256").digest(value.toByteArray(Charsets.UTF_8))
+        return digest.joinToString("") { byte -> "%02x".format(byte.toInt() and 0xff) }
+    }
+}
diff --git a/app/src/main/java/de/szalkowski/activitylauncher/data/audit/PackageAuditScanner.kt b/app/src/main/java/de/szalkowski/activitylauncher/data/audit/PackageAuditScanner.kt
