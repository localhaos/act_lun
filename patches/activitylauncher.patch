+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.Intent
+import android.content.pm.PackageManager
+import android.os.Build
+import de.szalkowski.activitylauncher.core.util.ActivityCommandBuilder
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchExecutor
+import de.szalkowski.activitylauncher.domain.launcher.ActivityLaunchResult
+import de.szalkowski.activitylauncher.domain.model.ActivityLaunchBackend
+import rikka.shizuku.Shizuku
+import java.util.concurrent.atomic.AtomicBoolean
+import javax.inject.Inject
+
+enum class ShizukuState {
+    UNSUPPORTED,
+    STOPPED,
+    DENIED,
+    GRANTED,
+}
+
+/**
+ * Shizuku-backed activity launcher. It sends an argument vector to `am` directly and never
+ * invokes `sh -c`, so component names and extras cannot become shell syntax.
+ */
+class ShizukuActivityLaunchExecutor @Inject constructor() : ActivityLaunchExecutor {
+    override val backend: ActivityLaunchBackend = ActivityLaunchBackend.SHIZUKU_PLUS
+
+    override fun isAvailable(): Boolean = Build.VERSION.SDK_INT >= Build.VERSION_CODES.N
+
+    fun state(): ShizukuState {
+        if (!isAvailable()) return ShizukuState.UNSUPPORTED
+        if (!runCatching { Shizuku.pingBinder() }.getOrDefault(false)) {
+            return ShizukuState.STOPPED
+        }
+        return if (hasPermission()) ShizukuState.GRANTED else ShizukuState.DENIED
+    }
+
+    fun hasPermission(): Boolean {
+        if (!isAvailable() || !runCatching { Shizuku.pingBinder() }.getOrDefault(false)) {
+            return false
+        }
+        return runCatching {
+            Shizuku.checkSelfPermission() == PackageManager.PERMISSION_GRANTED
+        }.getOrDefault(false)
+    }
+
+    fun requestPermission(callback: (Boolean) -> Unit) {
+        if (!isAvailable() || !runCatching { Shizuku.pingBinder() }.getOrDefault(false)) {
+            callback(false)
+            return
+        }
+        if (hasPermission()) {
+            callback(true)
+            return
+        }
+
+        val completed = AtomicBoolean(false)
+        val listener = object : Shizuku.OnRequestPermissionResultListener {
+            override fun onRequestPermissionResult(requestCode: Int, grantResult: Int) {
+                if (requestCode != REQUEST_CODE || !completed.compareAndSet(false, true)) return
+                Shizuku.removeRequestPermissionResultListener(this)
+                callback(grantResult == PackageManager.PERMISSION_GRANTED)
+            }
+        }
+
+        try {
+            Shizuku.addRequestPermissionResultListener(listener)
+            Shizuku.requestPermission(REQUEST_CODE)
+        } catch (error: Throwable) {
+            Shizuku.removeRequestPermissionResultListener(listener)
+            if (completed.compareAndSet(false, true)) callback(false)
+        }
+    }
+
+    override fun launch(intent: Intent): ActivityLaunchResult {
+        if (!isAvailable()) {
+            return ActivityLaunchResult(false, "Shizuku wymaga Androida 7.0 lub nowszego")
+        }
+        if (!runCatching { Shizuku.pingBinder() }.getOrDefault(false)) {
+            return ActivityLaunchResult(false, "Usługa Shizuku nie działa")
+        }
+        if (!hasPermission()) {
+            return ActivityLaunchResult(false, "Brak zgody Shizuku")
+        }
+
+        return runCatching {
+            val command = ActivityCommandBuilder.buildStartCommand(intent)
+            val process = newProcess(command)
+            process.outputStream.close()
+            Thread {
+                runCatching {
+                    process.waitFor()
+                }
+            }.apply {
+                name = "activitylauncher-shizuku-process"
+                isDaemon = true
+                start()
+            }
+            ActivityLaunchResult(started = true)
+        }.getOrElse { error ->
+            ActivityLaunchResult(
+                started = false,
+                message = error.message ?: error::class.java.simpleName,
+            )
+        }
+    }
+
+    private fun newProcess(command: List<String>): Process {
+        val method = Shizuku::class.java.getMethod(
+            "newProcess",
+            Array<String>::class.java,
+            Array<String>::class.java,
+            String::class.java,
+        )
+        return method.invoke(null, command.toTypedArray(), null, null) as Process
+    }
+
+    companion object {
+        private const val REQUEST_CODE = 2407
+    }
+}
