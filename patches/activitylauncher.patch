@@ -0,0 +1,192 @@
+package de.szalkowski.activitylauncher.data.knox
+
+import android.content.Context
+import android.content.Intent
+import android.os.Build
+import dagger.hilt.android.qualifiers.ApplicationContext
+import de.szalkowski.activitylauncher.BuildConfig
+import java.lang.reflect.InvocationTargetException
+import javax.inject.Inject
+import javax.inject.Singleton
+
+enum class KnoxLicenseState {
+    UNSUPPORTED,
+    NOT_CONFIGURED,
+    READY,
+    ACTIVATION_REQUESTED,
+    ACTIVE,
+    EXPIRED,
+    TERMINATED,
+    FAILED,
+}
+
+enum class KnoxActivationRequestResult {
+    REQUESTED,
+    UNSUPPORTED,
+    NOT_CONFIGURED,
+    INVALID_KEY,
+    FAILED,
+}
+
+data class KnoxLicenseStatus(
+    val state: KnoxLicenseState,
+    val errorCode: Int? = null,
+)
+
+@Singleton
+class KnoxLicenseManager @Inject constructor(
+    @ApplicationContext private val context: Context,
+) {
+    fun currentStatus(): KnoxLicenseStatus {
+        if (!isSupported()) return KnoxLicenseStatus(KnoxLicenseState.UNSUPPORTED)
+        if (BuildConfig.KNOX_KPE_LICENSE_KEY.isBlank()) {
+            return KnoxLicenseStatus(KnoxLicenseState.NOT_CONFIGURED)
+        }
+
+        queryActivationState()?.let { return it }
+
+        val preferences = context.getSharedPreferences(PREFERENCES_NAME, Context.MODE_PRIVATE)
+        val state =
+            runCatching {
+                KnoxLicenseState.valueOf(
+                    preferences.getString(KEY_STATE, KnoxLicenseState.READY.name)
+                        ?: KnoxLicenseState.READY.name,
+                )
+            }.getOrDefault(KnoxLicenseState.READY)
+        val errorCode =
+            if (preferences.contains(KEY_ERROR_CODE)) {
+                preferences.getInt(KEY_ERROR_CODE, DEFAULT_ERROR_CODE)
+            } else {
+                null
+            }
+        return KnoxLicenseStatus(state, errorCode)
+    }
+
+    fun activate(): KnoxActivationRequestResult {
+        if (!isSupported()) return KnoxActivationRequestResult.UNSUPPORTED
+
+        val rawKey = BuildConfig.KNOX_KPE_LICENSE_KEY
+        if (rawKey.isBlank()) return KnoxActivationRequestResult.NOT_CONFIGURED
+        val licenseKey =
+            normalizeKnoxLicenseKey(rawKey) ?: return KnoxActivationRequestResult.INVALID_KEY
+
+        return try {
+            val managerClass = Class.forName(KNOX_MANAGER_CLASS)
+            val getInstance = managerClass.getMethod("getInstance", Context::class.java)
+            val manager = getInstance.invoke(null, context) ?: return KnoxActivationRequestResult.FAILED
+            val activateLicense = managerClass.getMethod("activateLicense", String::class.java)
+            activateLicense.invoke(manager, licenseKey)
+            saveStatus(KnoxLicenseState.ACTIVATION_REQUESTED, null)
+            KnoxActivationRequestResult.REQUESTED
+        } catch (_: ClassNotFoundException) {
+            KnoxActivationRequestResult.UNSUPPORTED
+        } catch (_: NoSuchMethodException) {
+            KnoxActivationRequestResult.UNSUPPORTED
+        } catch (_: IllegalAccessException) {
+            KnoxActivationRequestResult.FAILED
+        } catch (_: InvocationTargetException) {
+            KnoxActivationRequestResult.FAILED
+        } catch (_: SecurityException) {
+            KnoxActivationRequestResult.FAILED
+        } catch (_: LinkageError) {
+            KnoxActivationRequestResult.FAILED
+        }
+    }
+
+    private fun isSupported(): Boolean {
+        if (!Build.MANUFACTURER.equals(SAMSUNG_MANUFACTURER, ignoreCase = true)) return false
+        return try {
+            Class.forName(KNOX_MANAGER_CLASS)
+            true
+        } catch (_: ClassNotFoundException) {
+            false
+        } catch (_: LinkageError) {
+            false
+        }
+    }
+
+    private fun queryActivationState(): KnoxLicenseStatus? {
+        return try {
+            val managerClass = Class.forName(KNOX_MANAGER_CLASS)
+            val manager =
+                managerClass.getMethod("getInstance", Context::class.java).invoke(null, context)
+                    ?: return null
+            val activationInfo =
+                managerClass.getMethod("getLicenseActivationInfo").invoke(manager) ?: return null
+            val stateName =
+                activationInfo.javaClass.getMethod("getState").invoke(activationInfo)?.toString()
+            when (stateName) {
+                "ACTIVE" -> KnoxLicenseStatus(KnoxLicenseState.ACTIVE)
+                "EXPIRED" -> KnoxLicenseStatus(KnoxLicenseState.EXPIRED)
+                "TERMINATED" -> KnoxLicenseStatus(KnoxLicenseState.TERMINATED)
+                else -> null
+            }
+        } catch (_: ReflectiveOperationException) {
+            null
+        } catch (_: SecurityException) {
+            null
+        } catch (_: LinkageError) {
+            null
+        }
+    }
+
+    private fun saveStatus(state: KnoxLicenseState, errorCode: Int?) {
+        val editor =
+            context.getSharedPreferences(PREFERENCES_NAME, Context.MODE_PRIVATE)
+                .edit()
+                .putString(KEY_STATE, state.name)
+        if (errorCode == null) {
+            editor.remove(KEY_ERROR_CODE)
+        } else {
+            editor.putInt(KEY_ERROR_CODE, errorCode)
+        }
+        editor.apply()
+    }
+
+    companion object {
+        internal const val ACTION_KNOX_LICENSE_STATUS =
+            "com.samsung.android.knox.intent.action.KNOX_LICENSE_STATUS"
+        private const val EXTRA_KNOX_LICENSE_ERROR_CODE =
+            "com.samsung.android.knox.intent.extra.KNOX_LICENSE_ERROR_CODE"
+        private const val EXTRA_KNOX_LICENSE_RESULT_TYPE =
+            "com.samsung.android.knox.intent.extra.KNOX_LICENSE_RESULT_TYPE"
+        private const val LICENSE_RESULT_TYPE_ACTIVATION = 800
+        private const val LICENSE_RESULT_TYPE_VALIDATION = 801
+        private const val ERROR_NONE = 0
+        private const val DEFAULT_ERROR_CODE = -1
+        private const val PREFERENCES_NAME = "knox_license_status"
+        private const val KEY_STATE = "state"
+        private const val KEY_ERROR_CODE = "error_code"
+        private const val KNOX_MANAGER_CLASS =
+            "com.samsung.android.knox.license.KnoxEnterpriseLicenseManager"
+        private const val SAMSUNG_MANUFACTURER = "samsung"
+
+        internal fun recordStatus(context: Context, intent: Intent) {
+            if (intent.action != ACTION_KNOX_LICENSE_STATUS) return
+            val resultType = intent.getIntExtra(EXTRA_KNOX_LICENSE_RESULT_TYPE, -1)
+            if (resultType != LICENSE_RESULT_TYPE_ACTIVATION &&
+                resultType != LICENSE_RESULT_TYPE_VALIDATION
+            ) {
+                return
+            }
+
+            val errorCode =
+                intent.getIntExtra(EXTRA_KNOX_LICENSE_ERROR_CODE, DEFAULT_ERROR_CODE)
+            val state =
+                if (errorCode == ERROR_NONE) KnoxLicenseState.ACTIVE else KnoxLicenseState.FAILED
+            val editor =
+                context.getSharedPreferences(PREFERENCES_NAME, Context.MODE_PRIVATE)
+                    .edit()
+                    .putString(KEY_STATE, state.name)
+                    .putInt(KEY_ERROR_CODE, errorCode)
+            editor.apply()
+        }
+    }
+}
+
+internal fun normalizeKnoxLicenseKey(value: String): String? {
+    val normalized = value.trim()
+    if (normalized.length !in 8..1024) return null
+    if (normalized.any { it.isISOControl() || it.isWhitespace() }) return null
+    return normalized
+}
diff --git a/app/src/main/java/de/szalkowski/activitylauncher/data/launcher/ActivityLaunchMethodTester.kt b/app/src/main/java/de/szalkowski/activitylauncher/data/launcher/ActivityLaunchMethodTester.kt
