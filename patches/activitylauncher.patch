@@ -48,6 +48,48 @@ abstract class PackageDao {
     abstract suspend fun deleteAllPackages(): Int
 }
 
+@Dao
+abstract class LaunchMethodDao {
+    @Query(
+        "SELECT * FROM launch_method_history " +
+            "WHERE packageName = :packageName AND className = :className " +
+            "ORDER BY successes DESC, lastSuccessAt DESC, lastAttemptAt DESC",
+    )
+    abstract suspend fun getHistory(packageName: String, className: String): List<LaunchMethodHistoryEntity>
+
+    @Query(
+        "SELECT * FROM launch_method_history " +
+            "WHERE packageName = :packageName AND className = :className AND backend = :backend LIMIT 1",
+    )
+    abstract suspend fun get(packageName: String, className: String, backend: String): LaunchMethodHistoryEntity?
+
+    @Insert(onConflict = OnConflictStrategy.REPLACE)
+    abstract suspend fun upsert(entry: LaunchMethodHistoryEntity): Long
+
+    suspend fun record(
+        packageName: String,
+        className: String,
+        backend: String,
+        success: Boolean,
+        message: String?,
+    ): Long {
+        val now = System.currentTimeMillis()
+        val previous = get(packageName, className, backend)
+        return upsert(
+            LaunchMethodHistoryEntity(
+                packageName = packageName,
+                className = className,
+                backend = backend,
+                attempts = (previous?.attempts ?: 0) + 1,
+                successes = (previous?.successes ?: 0) + if (success) 1 else 0,
+                lastAttemptAt = now,
+                lastSuccessAt = if (success) now else previous?.lastSuccessAt,
+                lastMessage = message,
+            ),
+        )
+    }
+}
