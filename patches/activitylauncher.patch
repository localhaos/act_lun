@@ -0,0 +1,203 @@
+package de.szalkowski.activitylauncher.data.launcher
+
+import android.content.ComponentName
+import android.content.ServiceConnection
+import android.content.pm.PackageManager
+import android.os.Build
+import android.os.IBinder
+import de.szalkowski.activitylauncher.BuildConfig
+import rikka.shizuku.Shizuku
+import java.util.concurrent.CountDownLatch
+import java.util.concurrent.TimeUnit
+import java.util.concurrent.atomic.AtomicBoolean
+import javax.inject.Inject
+import javax.inject.Singleton
+import kotlin.concurrent.thread
+
+data class ShizukuCommandResult(
+    val exitCode: Int,
+    val stdout: String,
+    val stderr: String,
+) {
+    val succeeded: Boolean get() = exitCode == 0
+
+    val message: String?
+        get() = (stderr.ifBlank { stdout }).trim().ifBlank { null }
+}
+
+/** Shared command bridge backed by the supported Shizuku UserService API. */
+@Singleton
+class ShizukuCommandExecutor @Inject constructor() {
+    private val connectionLock = Any()
+
+    @Volatile
+    private var service: IShizukuCommandService? = null
+
+    @Volatile
+    private var binding = false
+
+    @Volatile
+    private var connectionLatch = CountDownLatch(0)
+
+    private val userServiceArgs by lazy {
+        Shizuku.UserServiceArgs(
+            ComponentName(BuildConfig.APPLICATION_ID, ShizukuCommandUserService::class.java.name),
+        )
+            .daemon(false)
+            .processNameSuffix("activity_launcher_worker")
+            .debuggable(BuildConfig.DEBUG)
+            .version(BuildConfig.VERSION_CODE)
+    }
+
+    private val serviceConnection = object : ServiceConnection {
+        override fun onServiceConnected(name: ComponentName, binder: IBinder) {
+            val connected = IShizukuCommandService.Stub.asInterface(binder)
+                .takeIf { binder.pingBinder() }
+            synchronized(connectionLock) {
+                service = connected
+                binding = false
+                connectionLatch.countDown()
+            }
+        }
+
+        override fun onServiceDisconnected(name: ComponentName) {
+            synchronized(connectionLock) {
+                service = null
+                binding = false
+                connectionLatch.countDown()
+            }
+        }
+    }
+
+    fun isAvailable(): Boolean = Build.VERSION.SDK_INT >= Build.VERSION_CODES.M
+
+    fun state(): ShizukuState {
+        if (!isAvailable()) return ShizukuState.UNSUPPORTED
+        if (!runCatching { Shizuku.pingBinder() }.getOrDefault(false)) {
+            return ShizukuState.STOPPED
+        }
+        val unsupported = runCatching {
+            Shizuku.isPreV11() || Shizuku.getVersion() < MIN_USER_SERVICE_VERSION
+        }.getOrDefault(true)
+        if (unsupported) {
+            return ShizukuState.UNSUPPORTED
+        }
+        return if (hasPermission()) ShizukuState.GRANTED else ShizukuState.DENIED
+    }
+
+    fun remoteUid(): Int? {
+        if (state() != ShizukuState.GRANTED) return null
+        return runCatching { Shizuku.getUid() }.getOrNull()?.takeIf { it >= 0 }
+    }
+
+    fun hasPermission(): Boolean {
+        if (!isAvailable() || !runCatching { Shizuku.pingBinder() }.getOrDefault(false)) {
+            return false
+        }
+        return runCatching {
+            Shizuku.checkSelfPermission() == PackageManager.PERMISSION_GRANTED
+        }.getOrDefault(false)
+    }
+
+    fun requestPermission(callback: (Boolean) -> Unit) {
+        if (!isAvailable() || !runCatching { Shizuku.pingBinder() }.getOrDefault(false)) {
+            callback(false)
+            return
+        }
+        if (hasPermission()) {
+            prepare()
+            callback(true)
+            return
+        }
+        if (runCatching { Shizuku.shouldShowRequestPermissionRationale() }.getOrDefault(true)) {
+            callback(false)
+            return
+        }
+
+        val completed = AtomicBoolean(false)
+        val listener = object : Shizuku.OnRequestPermissionResultListener {
+            override fun onRequestPermissionResult(requestCode: Int, grantResult: Int) {
+                if (requestCode != REQUEST_CODE || !completed.compareAndSet(false, true)) return
+                Shizuku.removeRequestPermissionResultListener(this)
+                val granted = grantResult == PackageManager.PERMISSION_GRANTED
+                if (granted) prepare()
+                callback(granted)
+            }
+        }
+
+        try {
+            Shizuku.addRequestPermissionResultListener(listener)
+            Shizuku.requestPermission(REQUEST_CODE)
+        } catch (error: Throwable) {
+            Shizuku.removeRequestPermissionResultListener(listener)
+            if (completed.compareAndSet(false, true)) callback(false)
+        }
+    }
+
+    fun prepare() {
+        if (state() != ShizukuState.GRANTED || service?.asBinder()?.isBinderAlive == true) return
+        thread(start = true, isDaemon = true, name = "activitylauncher-shizuku-prepare") {
+            runCatching { requireService() }
+        }
+    }
+
+    fun execute(command: List<String>): ShizukuCommandResult {
+        check(state() == ShizukuState.GRANTED) { "Shizuku permission is not available" }
+        require(command.isNotEmpty()) { "Command must not be empty" }
+
+        val remote = requireService()
+        return runCatching {
+            val result = remote.execute(command.toTypedArray())
+            ShizukuCommandResult(
+                exitCode = result.getInt(ShizukuCommandUserService.RESULT_EXIT_CODE, PROCESS_FAILED),
+                stdout = result.getString(ShizukuCommandUserService.RESULT_STDOUT).orEmpty(),
+                stderr = result.getString(ShizukuCommandUserService.RESULT_STDERR).orEmpty(),
+            )
+        }.getOrElse { error ->
+            synchronized(connectionLock) {
+                service = null
+            }
+            throw error
+        }
+    }
+
+    private fun requireService(): IShizukuCommandService {
+        service?.takeIf { it.asBinder().isBinderAlive }?.let { return it }
+
+        var shouldBind = false
+        val latch = synchronized(connectionLock) {
+            service?.takeIf { it.asBinder().isBinderAlive }?.let { return it }
+            if (!binding) {
+                binding = true
+                connectionLatch = CountDownLatch(1)
+                shouldBind = true
+            }
+            connectionLatch
+        }
+
+        if (shouldBind) {
+            try {
+                Shizuku.bindUserService(userServiceArgs, serviceConnection)
+            } catch (error: Throwable) {
+                synchronized(connectionLock) {
+                    binding = false
+                    connectionLatch.countDown()
+                }
+                throw error
+            }
+        }
+
+        check(latch.await(CONNECTION_TIMEOUT_SECONDS, TimeUnit.SECONDS)) {
+            "Timed out while connecting to the Shizuku worker"
+        }
+        return service?.takeIf { it.asBinder().isBinderAlive }
+            ?: error("Shizuku worker did not return a live Binder")
+    }
+
+    companion object {
+        private const val REQUEST_CODE = 2407
+        private const val MIN_USER_SERVICE_VERSION = 10
+        private const val CONNECTION_TIMEOUT_SECONDS = 10L
+        private const val PROCESS_FAILED = 127
+    }
+}
