+++ b/app/src/main/java/de/szalkowski/activitylauncher/data/audit/PackageAuditScanner.kt
@@ -0,0 +1,170 @@
+package de.szalkowski.activitylauncher.data.audit
+
+import android.content.Context
+import android.content.pm.ApplicationInfo
+import android.content.pm.PackageManager
+import androidx.core.content.pm.PackageInfoCompat
+import dagger.hilt.android.qualifiers.ApplicationContext
+import de.szalkowski.activitylauncher.domain.audit.AuditFinding
+import de.szalkowski.activitylauncher.domain.audit.AuditFindingType
+import de.szalkowski.activitylauncher.domain.audit.AuditSeverity
+import de.szalkowski.activitylauncher.domain.audit.PackageAuditResult
+import java.io.ByteArrayOutputStream
+import java.io.File
+import java.util.zip.ZipFile
+import javax.inject.Inject
+
+class PackageAuditScanner @Inject constructor(
+    @ApplicationContext private val context: Context,
+) {
+    private val packageManager: PackageManager = context.packageManager
+
+    fun scan(packageName: String): PackageAuditResult {
+        @Suppress("DEPRECATION")
+        val packageInfo = packageManager.getPackageInfo(packageName, PackageManager.GET_ACTIVITIES)
+        val applicationInfo = packageInfo.applicationInfo
+            ?: throw PackageManager.NameNotFoundException(packageName)
+        val apkFile = applicationInfo.sourceDir?.let(::File)
+        val findings = linkedMapOf<String, AuditFinding>()
+        var scanTruncated = false
+
+        fun add(finding: AuditFinding) {
+            val key = "${finding.type}|${finding.value}|${finding.source}"
+            findings.putIfAbsent(key, finding)
+        }
+
+        val debuggable = applicationInfo.flags and ApplicationInfo.FLAG_DEBUGGABLE != 0
+        val testOnly = applicationInfo.flags and ApplicationInfo.FLAG_TEST_ONLY != 0
+        if (debuggable) {
+            add(
+                AuditFinding(
+                    type = AuditFindingType.DEBUG_MARKER,
+                    severity = AuditSeverity.HIGH,
+                    value = "android:debuggable=true",
+                    source = "ApplicationInfo.flags",
+                    details = "Flaga aplikacji jest ustawiona w zainstalowanym pakiecie.",
+                ),
+            )
+        }
+        if (testOnly) {
+            add(
+                AuditFinding(
+                    type = AuditFindingType.DEBUG_MARKER,
+                    severity = AuditSeverity.MEDIUM,
+                    value = "android:testOnly=true",
+                    source = "ApplicationInfo.flags",
+                    details = "Pakiet został oznaczony jako testowy.",
+                ),
+            )
+        }
+
+        val nativeLibraries = mutableListOf<String>()
+        var lombokSclCount = 0
+        var asmSclCount = 0
+        apkFile?.takeIf { it.isFile }?.let { file ->
+            runCatching {
+                ZipFile(file).use { zip ->
+                    var scannedBytes = 0L
+                    zip.entries().asSequence().forEach { entry ->
+                        if (entry.name.startsWith("lib/") && entry.name.endsWith(".so")) {
+                            nativeLibraries += entry.name
+                        }
+                        if (entry.name.endsWith(".SCL.lombok")) {
+                            lombokSclCount++
+                            if (entry.name.startsWith("org/objectweb/asm/")) asmSclCount++
+                        }
+                        if (!isScannable(entry.name) || findings.size >= MAX_FINDINGS) return@forEach
+                        val entrySize = entry.size.takeIf { it >= 0 } ?: MAX_ENTRY_BYTES.toLong()
+                        if (entrySize > MAX_ENTRY_BYTES || scannedBytes >= MAX_TOTAL_BYTES) {
+                            scanTruncated = true
+                            return@forEach
+                        }
+                        val bytes = readEntry(zip, entry, MAX_ENTRY_BYTES)
+                        scannedBytes += bytes.size
+                        val texts = listOf(
+                            String(bytes, Charsets.ISO_8859_1),
+                            String(bytes, Charsets.UTF_8),
+                            String(bytes, Charsets.UTF_16LE),
+                        )
+                        texts.flatMap { text -> AuditDetector.detect(text, entry.name) }
+                            .take(MAX_FINDINGS - findings.size)
+                            .forEach(::add)
+                    }
+                }
+            }.onFailure {
+                scanTruncated = true
+            }
+        }
+        if (lombokSclCount > 0) {
+            add(
+                AuditFinding(
+                    type = AuditFindingType.BUILD_TOOL_PAYLOAD,
+                    severity = AuditSeverity.LOW,
+                    value = "Lombok SCL: $lombokSclCount (ASM: $asmSclCount)",
+                    source = "APK ZIP entries",
+                    details =
+                    "Klasy narzędzia kompilacyjnego są spakowane jako zasoby; ART nie uruchamia ich bezpośrednio.",
+                ),
+            )
+        }
+
+        val activities = packageInfo.activities.orEmpty()
+        activities.filter { it.exported && it.permission.isNullOrBlank() }.forEach { activity ->
+            add(
+                AuditFinding(
+                    type = AuditFindingType.EXPORTED_COMPONENT,
+                    severity = AuditSeverity.MEDIUM,
+                    value = activity.name,
+                    source = "AndroidManifest.xml",
+                    details = "Aktywność jest eksportowana bez permission; zweryfikuj kontrolę dostępu i walidację wejścia.",
+                ),
+            )
+        }
+        return PackageAuditResult(
+            packageName = packageName,
+            label = packageManager.getApplicationLabel(applicationInfo).toString(),
+            versionName = packageInfo.versionName,
+            versionCode = PackageInfoCompat.getLongVersionCode(packageInfo),
+            apkPath = applicationInfo.sourceDir,
+            debuggable = debuggable,
+            testOnly = testOnly,
+            activityCount = activities.size,
+            exportedActivityCount = activities.count { it.exported },
+            nativeLibraries = nativeLibraries.distinct().sorted(),
+            findings = findings.values.take(MAX_FINDINGS).toList(),
+            scanTruncated = scanTruncated || findings.size >= MAX_FINDINGS,
+        )
+    }
+
+    private fun isScannable(name: String): Boolean {
+        return name.endsWith(".dex") ||
+            name.endsWith(".xml") ||
+            name.endsWith(".json") ||
+            name.endsWith(".txt") ||
+            name.endsWith(".properties") ||
+            name.startsWith("assets/") ||
+            name.startsWith("res/raw/") ||
+            name.startsWith("META-INF/")
+    }
+
+    private fun readEntry(zip: ZipFile, entry: java.util.zip.ZipEntry, limit: Int): ByteArray {
+        val output = ByteArrayOutputStream(minOf(entry.size.takeIf { it >= 0 }?.toInt() ?: limit, limit))
+        zip.getInputStream(entry).use { input ->
+            val buffer = ByteArray(DEFAULT_BUFFER_SIZE)
+            var remaining = limit
+            while (remaining > 0) {
+                val count = input.read(buffer, 0, minOf(buffer.size, remaining))
+                if (count <= 0) break
+                output.write(buffer, 0, count)
+                remaining -= count
+            }
+        }
+        return output.toByteArray()
+    }
+
+    private companion object {
+        const val MAX_ENTRY_BYTES = 8 * 1024 * 1024
+        const val MAX_TOTAL_BYTES = 64L * 1024 * 1024
+        const val MAX_FINDINGS = 256
+    }
+}
diff --git a/app/src/main/java/de/szalkowski/activitylauncher/data/knox/KnoxLicenseManager.kt b/app/src/main/java/de/szalkowski/activitylauncher/data/knox/KnoxLicenseManager.kt
