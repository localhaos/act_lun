+    fun read(uri: Uri): Intent? {
+        if (uri.scheme != SCHEME || uri.authority.isNullOrBlank() || uri.authority!!.contains('@')) return null
+        val type = context.contentResolver.getType(uri)
+        if (type != null && type !in ALLOWED_TYPES) return null
+        return runCatching {
+            val bytes = context.contentResolver.openInputStream(uri)?.use { input ->
+                val output = java.io.ByteArrayOutputStream()
+                val buffer = ByteArray(4096)
+                while (output.size() <= MAX_BYTES) {
+                    val count = input.read(buffer)
+                    if (count < 0) break
+                    output.write(buffer, 0, count)
+                }
+                output.toByteArray()
+            } ?: return null
+            if (bytes.size > MAX_BYTES) return null
+            parseText(bytes.toString(Charsets.UTF_8))
+        }.getOrNull()
+    }
+
+    companion object {
+        const val SCHEME = "content"
+        private const val MAX_BYTES = 64 * 1024
+        private val ALLOWED_TYPES = setOf(
+            "text/plain",
+            "text/uri-list",
+            "application/json",
+            "application/vnd.android.intent",
+        )
+
+        fun parseText(value: String): Intent? {
+            val candidate = value.trim()
+            if (candidate.isEmpty() || candidate.any { it == '\u0000' }) return null
+            val intent = runCatching {
+                Intent.parseUri(candidate, Intent.URI_INTENT_SCHEME)
+            }.getOrNull() ?: return null
+            return intent.takeIf { it.component != null }
+        }
+    }
+}
