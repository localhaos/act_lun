+++ b/app/src/main/java/de/szalkowski/activitylauncher/presentation/audit/PackageAuditFormatter.kt
@@ -0,0 +1,54 @@
+package de.szalkowski.activitylauncher.presentation.audit
+
+import de.szalkowski.activitylauncher.domain.audit.AuditFindingType
+import de.szalkowski.activitylauncher.domain.audit.PackageAuditResult
+
+object PackageAuditFormatter {
+    fun format(result: PackageAuditResult): String = buildString {
+        appendLine("Pakiet: ${result.packageName}")
+        appendLine("Nazwa: ${result.label}")
+        appendLine("Wersja: ${result.versionName ?: "?"} (${result.versionCode})")
+        appendLine("APK: ${result.apkPath ?: "?"}")
+        appendLine("Debuggable: ${result.debuggable}")
+        appendLine("Test-only: ${result.testOnly}")
+        appendLine("Aktywności: ${result.activityCount}; exported: ${result.exportedActivityCount}")
+        appendLine()
+
+        appendLine("== SECRET CODES ==")
+        appendFindings(result, AuditFindingType.SECRET_CODE)
+        appendLine()
+
+        appendLine("== DEBUG / DEVELOPER MARKERS ==")
+        appendFindings(result, AuditFindingType.DEBUG_MARKER)
+        appendLine()
+
+        appendLine("== SENSITIVE LITERAL CANDIDATES ==")
+        appendFindings(result, AuditFindingType.SENSITIVE_LITERAL)
+        appendLine("Wartości wrażliwe są celowo redagowane; wynik wymaga ręcznej weryfikacji.")
+        appendLine()
+
+        appendLine("== NATIVE LIBRARIES ==")
+        if (result.nativeLibraries.isEmpty()) {
+            appendLine("brak")
+        } else {
+            result.nativeLibraries.forEach { appendLine(it) }
+        }
+        if (result.scanTruncated) {
+            appendLine()
+            appendLine("Uwaga: skan został ograniczony limitem rozmiaru/liczby wyników.")
+        }
+    }
+
+    private fun StringBuilder.appendFindings(result: PackageAuditResult, type: AuditFindingType) {
+        val findings = result.findings.filter { it.type == type }
+        if (findings.isEmpty()) {
+            appendLine("brak")
+            return
+        }
+        findings.forEach { finding ->
+            append("[${finding.severity}] ${finding.value} @ ${finding.source}")
+            finding.details?.let { append(" — $it") }
+            appendLine()
+        }
+    }
+}
