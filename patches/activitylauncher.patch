new file mode 100644
index 0000000..f3b5b98
--- /dev/null
+++ b/app/src/main/cpp/activitylauncher_worker.cpp
@@ -0,0 +1,100 @@
+#include <jni.h>
+
+#include <cerrno>
+#include <string>
+#include <sys/wait.h>
+#include <unistd.h>
+#include <vector>
+
+namespace {
+constexpr const char* kActivityManager = "/system/bin/am";
+constexpr size_t kMaxArguments = 64;
+constexpr size_t kMaxArgumentLength = 4096;
+
+bool isSafeArgument(const char* value) {
+    if (value == nullptr) return false;
+    size_t length = 0;
+    while (value[length] != '\0') {
+        if (++length > kMaxArgumentLength) return false;
+    }
+    return true;
+}
+}  // namespace
+
+extern "C" JNIEXPORT jint JNICALL
+Java_de_szalkowski_activitylauncher_data_launcher_NativeWorker_nativeSpawn(
+    JNIEnv* env,
+    jclass,
+    jobjectArray command
+) {
+    if (command == nullptr) return -EINVAL;
+
+    const jsize count = env->GetArrayLength(command);
+    if (count < 1 || static_cast<size_t>(count) > kMaxArguments) return -EINVAL;
+
+    std::vector<std::string> values;
+    values.reserve(static_cast<size_t>(count));
+    for (jsize index = 0; index < count; ++index) {
+        auto value = static_cast<jstring>(env->GetObjectArrayElement(command, index));
+        if (value == nullptr) return -EINVAL;
+        const char* utf = env->GetStringUTFChars(value, nullptr);
+        if (!isSafeArgument(utf)) {
+            env->ReleaseStringUTFChars(value, utf);
+            env->DeleteLocalRef(value);
+            return -EINVAL;
+        }
+        values.emplace_back(utf);
+        env->ReleaseStringUTFChars(value, utf);
+        env->DeleteLocalRef(value);
+    }
+
+    // The worker accepts only the fixed activity-manager start operation; it never invokes a shell.
+    if (values.front() != kActivityManager || values.size() < 2 || values[1] != "start") {
+        return -EPERM;
+    }
+
+    std::vector<char*> argv;
+    argv.reserve(values.size() + 1);
+    for (auto& value : values) argv.push_back(value.data());
+    argv.push_back(nullptr);
+
+    const pid_t child = fork();
+    if (child < 0) return -errno;
+    if (child == 0) {
+        execv(kActivityManager, argv.data());
+        _exit(127);
+    }
+    return static_cast<jint>(child);
+}
+
+extern "C" JNIEXPORT jint JNICALL
+Java_de_szalkowski_activitylauncher_data_launcher_NativeWorker_nativeAbiLevel(
+    JNIEnv*,
+    jclass
+) {
+#if defined(__aarch64__)
+    return 1;
+#elif defined(__arm__)
+    return 2;
+#elif defined(__x86_64__)
+    return 3;
+#elif defined(__i386__)
+    return 4;
+#else
+    return 0;
+#endif
+}
+
+extern "C" JNIEXPORT jint JNICALL
+Java_de_szalkowski_activitylauncher_data_launcher_NativeWorker_nativeWaitFor(
+    JNIEnv*,
+    jclass,
+    jint pid
+) {
+    if (pid <= 0) return -EINVAL;
+    int status = 0;
+    if (waitpid(static_cast<pid_t>(pid), &status, 0) < 0) return -errno;
+    if (WIFEXITED(status)) return WEXITSTATUS(status);
+    if (WIFSIGNALED(status)) return 128 + WTERMSIG(status);
+    return -ECHILD;
+}
