@@ -0,0 +1,48 @@
+package de.szalkowski.activitylauncher.data.audit
+
+import de.szalkowski.activitylauncher.domain.audit.AuditFindingType
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertFalse
+import org.junit.Assert.assertTrue
+import org.junit.Test
+
+class AuditDetectorTest {
+    @Test
+    fun `detects dialer and android secret code formats`() {
+        val findings = AuditDetector.detect(
+            "dial *#*#4636#*#* and android_secret_code://4268",
+            "classes.dex",
+        )
+
+        val values = findings.filter { it.type == AuditFindingType.SECRET_CODE }.map { it.value }
+        assertEquals(
+            listOf("*#*#4636#*#*", "android_secret_code://4268"),
+            values,
+        )
+    }
+
+    @Test
+    fun `redacts sensitive values and keeps only a digest`() {
+        val findings = AuditDetector.detect(
+            "developer_password=NotForDisplay123; password='AnotherSecret456'",
+            "assets/config.txt",
+        )
+
+        val sensitive = findings.filter { it.type == AuditFindingType.SENSITIVE_LITERAL }
+        assertTrue(sensitive.any { it.value == "developer_password" })
+        assertTrue(sensitive.any { it.value == "password" })
+        assertTrue(sensitive.all { it.details?.contains("[REDACTED]") == false })
+        assertTrue(sensitive.all { it.details?.contains("SHA-256=") == true })
+        assertFalse(sensitive.any { it.details?.contains("NotForDisplay123") == true })
+        assertFalse(sensitive.any { it.details?.contains("AnotherSecret456") == true })
+    }
+
+    @Test
+    fun `detects debug markers without treating them as proof of debuggable flag`() {
+        val findings = AuditDetector.detect("strictmode developer trace", "res/values.xml")
+        val markers = findings.filter { it.type == AuditFindingType.DEBUG_MARKER }.map { it.value }.toSet()
+
+        assertTrue(markers.containsAll(setOf("strictmode", "developer", "trace")))
+        assertTrue(findings.all { it.details?.contains("nie potwierdza") == true })
+    }
+}
