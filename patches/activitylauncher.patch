+package de.szalkowski.activitylauncher.domain.model
+
+/**
+ * Backend used to start an activity.
+ *
+ * JVM and JNI_NATIVE do not grant additional privileges. They are explicit process-launch
+ * backends for diagnostics and compatibility testing. SHIZUKU_PLUS requires a user-approved
+ * Shizuku grant. ROOT_SU requires an already-installed root manager and explicit user approval.
+ */
+enum class ActivityLaunchBackend(val displayName: String) {
+    DEFAULT("Android framework / ART"),
+    SHIZUKU_PLUS("Shizuku / compatible Shizuku+"),
+    ROOT_PLUGIN("Signed Root Activity Launcher plugin"),
+    ROOT_SU("Root manager"),
+    JVM("Java process on ART"),
+    JNI_NATIVE("JNI native worker"),
+}
