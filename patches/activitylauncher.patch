@@ -0,0 +1,116 @@
+package de.szalkowski.activitylauncher.data.launcher
+
+import java.io.File
+import java.io.InputStream
+import javax.inject.Inject
+import kotlin.concurrent.thread
+
+data class RootCommandResult(
+    val exitCode: Int,
+    val stdout: String,
+    val stderr: String,
+    val strategy: String,
+) {
+    val succeeded: Boolean get() = exitCode == 0
+
+    val message: String?
+        get() = (stderr.ifBlank { stdout }).trim().ifBlank { null }
+}
+
+/** Runs only allowlisted Android framework tools through an already-installed root manager. */
+class RootCommandExecutor @Inject constructor() {
+    fun isAvailable(): Boolean = findSu() != null
+
+    fun execute(command: List<String>): RootCommandResult {
+        require(command.isNotEmpty() && command.first() in ALLOWED_EXECUTABLES) {
+            "Root command executable is not allowed"
+        }
+        val su = findSu() ?: return RootCommandResult(
+            exitCode = ROOT_UNAVAILABLE,
+            stdout = "",
+            stderr = "Nie znaleziono wykonywalnego su/root managera",
+            strategy = "unavailable",
+        )
+
+        val strategies = buildList {
+            add("su-user-separator" to (listOf(su, "0", "--") + command))
+            add("su-user-direct" to (listOf(su, "0") + command))
+            add("su-command" to listOf(su, "-c", command.toShellCommand()))
+            findToybox()?.let { toybox ->
+                add("system-toybox" to (listOf(su, "0", "--", toybox, "env") + command))
+            }
+        }
+
+        var lastResult: RootCommandResult? = null
+        for ((name, arguments) in strategies) {
+            val result = runCatching { runProcess(arguments, name) }.getOrElse { error ->
+                RootCommandResult(
+                    exitCode = PROCESS_FAILED,
+                    stdout = "",
+                    stderr = error.message ?: error::class.java.simpleName,
+                    strategy = name,
+                )
+            }
+            if (result.succeeded) return result
+            lastResult = result
+        }
+        return requireNotNull(lastResult)
+    }
+
+    private fun runProcess(arguments: List<String>, strategy: String): RootCommandResult {
+        val process = ProcessBuilder(arguments).redirectErrorStream(false).start()
+        process.outputStream.close()
+        val stdout = StringBuilder()
+        val stderr = StringBuilder()
+        val stdoutReader = thread(start = true, isDaemon = true, name = "activitylauncher-root-stdout") {
+            stdout.append(process.inputStream.readTextBounded())
+        }
+        val stderrReader = thread(start = true, isDaemon = true, name = "activitylauncher-root-stderr") {
+            stderr.append(process.errorStream.readTextBounded())
+        }
+        val exitCode = process.waitFor()
+        stdoutReader.join()
+        stderrReader.join()
+        return RootCommandResult(exitCode, stdout.toString(), stderr.toString(), strategy)
+    }
+
+    private fun InputStream.readTextBounded(): String = bufferedReader().use { reader ->
+        buildString {
+            val buffer = CharArray(1024)
+            while (true) {
+                val count = reader.read(buffer)
+                if (count < 0) break
+                val remaining = MAX_OUTPUT_CHARS - length
+                if (remaining > 0) append(buffer, 0, minOf(count, remaining))
+            }
+        }
+    }
+
+    private fun findSu(): String? = SU_CANDIDATES.firstOrNull { File(it).canExecute() }
+
+    private fun findToybox(): String? = TOYBOX_CANDIDATES.firstOrNull { File(it).canExecute() }
+
+    private fun List<String>.toShellCommand(): String = joinToString(" ") { argument ->
+        "'${argument.replace("'", "'\"'\"'")}'"
+    }
+
+    private companion object {
+        const val ROOT_UNAVAILABLE = 126
+        const val PROCESS_FAILED = 127
+        const val MAX_OUTPUT_CHARS = 16_384
+
+        val ALLOWED_EXECUTABLES = setOf("/system/bin/am", "/system/bin/pm")
+        val SU_CANDIDATES = listOf(
+            "/system/bin/su",
+            "/system/xbin/su",
+            "/sbin/su",
+            "/su/bin/su",
+            "/debug_ramdisk/su",
+        )
+        val TOYBOX_CANDIDATES = listOf(
+            "/system/bin/toybox",
+            "/system/xbin/toybox",
+            "/vendor/bin/toybox",
+        )
+    }
+}
diff --git a/app/src/main/java/de/szalkowski/activitylauncher/data/launcher/RootPackageStateExecutor.kt b/app/src/main/java/de/szalkowski/activitylauncher/data/launcher/RootPackageStateExecutor.kt
